<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeSidebar" owl="1">
        <aside class="o_studio_ce_sidebar bg-white border-end d-flex flex-column flex-shrink-0 h-100 overflow-auto" style="width: 320px;">
            <!-- Tab Switchers -->
            <ul class="nav nav-tabs nav-fill flex-shrink-0 border-bottom">
                <li class="nav-item">
                    <button class="nav-link py-2" t-att-class="{ active: props.activeTab === 'fields' }" t-on-click="() => props.onTabChange('fields')">Fields</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link py-2" t-att-class="{ active: props.activeTab === 'views' }" t-on-click="() => props.onTabChange('views')">Views</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link py-2" t-att-class="{ active: props.activeTab === 'automations' }" t-on-click="() => props.onTabChange('automations')">Rules</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link py-2" t-att-class="{ active: props.activeTab === 'approvals' }" t-on-click="() => props.onTabChange('approvals')">Approvals</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link py-2" t-att-class="{ active: props.activeTab === 'logs' }" t-on-click="() => props.onTabChange('logs')">History</button>
                </li>
            </ul>

            <div class="tab-content p-3 flex-grow-1">
                
                <!-- 1. Fields Tab -->
                <div t-if="props.activeTab === 'fields'" class="tab-pane show active">
                    <!-- If field selected, render properties instead -->
                    <t t-if="props.selectedField">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-dark">Properties</h5>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-2" t-on-click="() => props.onDeselectField()">✕ Clear</button>
                        </div>

                        <t t-if="props.selectedField.ttype === 'properties'">
                            <PropertiesBuilder fieldName="props.selectedField.name" modelName="props.modelName"/>
                        </t>
                        <t t-else="">
                            <!-- Properties Inputs (Per-View Overrides) -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Field Label</label>
                                <input type="text" class="form-control form-control-sm"
                                       t-att-value="props.selectedField.field_description"
                                       t-on-change="(ev) => this.overrideProperty('label', ev.target.value)"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Technical Name</label>
                                <input type="text" class="form-control form-control-sm bg-light" readonly="1"
                                       t-att-value="props.selectedField.name"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Field Type</label>
                                <input type="text" class="form-control form-control-sm bg-light text-capitalize" readonly="1"
                                       t-att-value="props.selectedField.ttype"/>
                            </div>

                            <div class="form-check mb-2">
                                <input type="checkbox" class="form-check-input" id="prop_req"
                                       t-att-checked="props.selectedField.required"
                                       t-on-change="(ev) => this.overrideProperty('required', ev.target.checked ? '1' : '0')"/>
                                <label class="form-check-label text-dark small" for="prop_req">Required field</label>
                            </div>

                            <div class="form-check mb-2">
                                <input type="checkbox" class="form-check-input" id="prop_inv"
                                       t-att-checked="props.selectedField.invisible"
                                       t-on-change="(ev) => this.overrideProperty('invisible', ev.target.checked ? '1' : '0')"/>
                                <label class="form-check-label text-dark small" for="prop_inv">Invisible / Hidden</label>
                            </div>

                            <div class="form-check mb-3">
                                <input type="checkbox" class="form-check-input" id="prop_ro"
                                       t-att-checked="props.selectedField.readonly"
                                       t-on-change="(ev) => this.overrideProperty('readonly', ev.target.checked ? '1' : '0')"/>
                                <label class="form-check-label text-dark small" for="prop_ro">Read-only field</label>
                            </div>

                            <!-- Override Widget -->
                            <div class="mb-3 border-top pt-2">
                                <label class="form-label text-secondary small fw-bold">Widget</label>
                                <select class="form-select form-select-sm"
                                        t-on-change="(ev) => this.overrideProperty('widget', ev.target.value)">
                                    <option value="">Default</option>
                                    <option value="many2many_tags">Tags (many2many_tags)</option>
                                    <option value="monetary">Monetary</option>
                                    <option value="percentage">Percentage</option>
                                    <option value="phone">Phone</option>
                                    <option value="email">Email</option>
                                    <option value="url">URL</option>
                                    <option value="image">Image</option>
                                    <option value="selection">Selection</option>
                                    <option value="html">HTML</option>
                                    <option value="binary">Binary</option>
                                </select>
                            </div>

                            <!-- Override Placeholder -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Placeholder</label>
                                <input type="text" class="form-control form-control-sm"
                                       placeholder="Enter help text..."
                                       t-on-change="(ev) => this.overrideProperty('placeholder', ev.target.value)"/>
                            </div>

                            <!-- Computed Field Section -->
                            <div class="mb-3 border-top pt-3">
                                <div class="form-check mb-2">
                                    <input type="checkbox" class="form-check-input" id="prop_is_compute"
                                           t-att-checked="props.selectedField.compute ? true : false"
                                           t-on-change="(ev) => this.updateProperty('compute', ev.target.checked ? '# Write your Python code here\n# Available variables:\n#  - self: recordset\nfor record in self:\n    record[\'' + props.selectedField.name + '\'] = False' : '')"/>
                                    <label class="form-check-label text-dark small" for="prop_is_compute">Computed field</label>
                                </div>
                                <div t-if="props.selectedField.compute" class="mb-2">
                                    <label class="form-label text-secondary small fw-bold">Dependencies</label>
                                    <input type="text" class="form-control form-control-sm"
                                           placeholder="e.g. x_field1,x_field2"
                                           t-att-value="props.selectedField.depends"
                                           t-on-change="(ev) => this.updateProperty('depends', ev.target.value)"/>
                                </div>
                                <div t-if="props.selectedField.compute" class="mb-2">
                                    <label class="form-label text-secondary small fw-bold">Python Code</label>
                                    <textarea class="form-control form-control-sm font-monospace" rows="5" style="font-size:0.75rem;"
                                              t-att-value="props.selectedField.compute"
                                              t-on-change="(ev) => this.updateProperty('compute', ev.target.value)"/>
                                </div>
                            </div>

                            <!-- Relational Link -->
                            <div t-if="['many2one', 'one2many', 'many2many'].includes(props.selectedField.ttype)" class="mb-3 border-top pt-3">
                                <label class="form-label text-secondary small fw-bold">Related Model</label>
                                <input type="text" class="form-control form-control-sm"
                                       placeholder="e.g. res.partner"
                                       t-att-value="props.selectedField.relation"
                                       t-on-change="(ev) => this.updateProperty('relation', ev.target.value)"/>
                            </div>

                            <!-- Selection Options -->
                            <div t-if="props.selectedField.ttype === 'selection'" class="mb-3 border-top pt-3">
                                <label class="form-label text-secondary small fw-bold">Selection Options</label>
                                <div class="list-group mb-2 border rounded">
                                    <t t-foreach="props.selectedField.selectionOptions || []" t-as="option" t-key="option[0]">
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-1 px-2 small bg-light">
                                            <span><strong t-esc="option[0]"/>: <t t-esc="option[1]"/></span>
                                            <button class="btn btn-sm text-danger p-0 border-0 bg-transparent font-weight-bold" t-on-click="() => this.removeSelectionOption(option[0])">✕</button>
                                        </div>
                                    </t>
                                </div>
                                <div class="input-group input-group-sm mb-1">
                                    <input type="text" class="form-control" placeholder="Key" t-model="state.newOptionKey"/>
                                    <input type="text" class="form-control" placeholder="Label" t-model="state.newOptionValue"/>
                                    <button class="btn btn-primary" t-on-click="addSelectionOption">+</button>
                                </div>
                            </div>
                        </t>
                    </t>

                    <t t-else="">
                        <h5 class="fw-bold mb-2">Add Custom Field</h5>
                        <div class="d-grid gap-1 mb-4 overflow-auto" style="max-height: 250px; border: 1px solid #eee; padding: 5px; border-radius: 4px;">
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'char')" t-on-click="() => props.onAddField('char', 'Custom Label')">+ Text (Char)</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'integer')" t-on-click="() => props.onAddField('integer', 'Custom Integer')">+ Integer</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'float')" t-on-click="() => props.onAddField('float', 'Custom Float')">+ Float</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'monetary')" t-on-click="() => props.onAddField('monetary', 'Custom Monetary')">+ Monetary</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'date')" t-on-click="() => props.onAddField('date', 'Custom Date')">+ Date</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'datetime')" t-on-click="() => props.onAddField('datetime', 'Custom Datetime')">+ Datetime</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'boolean')" t-on-click="() => props.onAddField('boolean', 'Custom Checkbox')">+ Checkbox (Boolean)</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'selection')" t-on-click="() => props.onAddField('selection', 'Selection List')">+ Selection Dropdown</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'many2one')" t-on-click="() => props.onAddField('many2one', 'Related Link (m2o)')">+ Relation (Many2one)</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'many2many')" t-on-click="() => props.onAddField('many2many', 'Relation Tags (m2m)')">+ Relation (Many2many)</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'binary')" t-on-click="() => props.onAddField('binary', 'Custom Binary File')">+ Binary File</button>
                            <button class="btn btn-outline-primary btn-sm text-start py-1" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'html')" t-on-click="() => props.onAddField('html', 'Custom HTML Area')">+ HTML Field</button>
                        </div>

                        <h5 class="fw-bold mb-2">Existing Fields</h5>
                        <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 250px;">
                            <t t-foreach="props.fields" t-as="field" t-key="field.id">
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3"
                                     draggable="true"
                                     t-on-dragstart="(ev) => this.onDragStartExistingField(ev, field.name, field.field_description)">
                                    <div class="text-truncate me-2 cursor-pointer" t-on-click="() => props.onSelectField(field)">
                                        <div class="fw-bold text-dark text-truncate small"><t t-esc="field.field_description"/></div>
                                        <small class="text-muted font-monospace" style="font-size:0.75rem;"><t t-esc="field.name"/></small>
                                    </div>
                                    <button class="btn btn-sm btn-link py-0 px-1 text-primary flex-shrink-0" 
                                            t-if="props.views.length > 0"
                                            t-on-click="() => props.onAddFieldToView(props.views[0].id, field.name)">
                                        Add
                                    </button>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- 2. Views Tab -->
                <div t-if="props.activeTab === 'views'" class="tab-pane show active">
                    <h5 class="fw-bold mb-3">Model Views</h5>
                    <div class="list-group list-group-flush border rounded">
                        <t t-foreach="props.views" t-as="view" t-key="view.id">
                            <div class="list-group-item list-group-item-action py-2 px-3 cursor-pointer"
                                 t-on-click="() => props.onViewChange(view.id)">
                                <div class="fw-bold text-capitalize text-dark small"><t t-esc="view.type"/> View</div>
                                <div class="text-muted font-monospace" style="font-size:0.75rem;"><t t-esc="view.name"/></div>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- 3. Automations Tab -->
                <div t-if="props.activeTab === 'automations'" class="tab-pane show active">
                    <t t-if="state.selectedRule">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-dark">Rule Properties</h5>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-2" t-on-click="() => this.deselectRule()">✕ Back</button>
                        </div>
                        <AutomationEditor rule="state.selectedRule" fields="props.fields" onRuleUpdated.bind="onRuleUpdated"/>
                    </t>
                    <t t-else="">
                        <h5 class="fw-bold mb-3">Automated Actions</h5>
                        <button class="btn btn-primary btn-sm w-100 mb-3" t-on-click="props.onAddAutomation">
                            Create Rule
                        </button>
                        <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 350px;">
                            <t t-foreach="props.automations" t-as="auto" t-key="auto.id">
                                <div class="list-group-item list-group-item-action py-2 px-3 cursor-pointer" t-on-click="() => this.selectRule(auto)">
                                    <div class="fw-bold text-dark small"><t t-esc="auto.name"/></div>
                                    <small class="badge bg-secondary" style="font-size:0.7rem;"><t t-esc="auto.trigger"/></small>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- 3.5. Approvals Tab -->
                <div t-if="props.activeTab === 'approvals'" class="tab-pane show active">
                    <t t-if="state.selectedApproval">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-dark">Approval Properties</h5>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-2" t-on-click="() => this.deselectApproval()">✕ Back</button>
                        </div>
                        <ApprovalEditor approval="state.selectedApproval" groups="props.groups" modelName="props.modelName" onApprovalUpdated.bind="onApprovalUpdated"/>
                    </t>
                    <t t-else="">
                        <h5 class="fw-bold mb-3">Approval Workflows</h5>
                        <button class="btn btn-primary btn-sm w-100 mb-3" t-on-click="props.onAddApproval">
                            Create Workflow
                        </button>
                        <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 350px;">
                            <t t-foreach="props.approvals || []" t-as="app" t-key="app.id">
                                <div class="list-group-item list-group-item-action py-2 px-3 cursor-pointer" t-on-click="() => this.selectApproval(app)">
                                    <div class="fw-bold text-dark small"><t t-esc="app.name"/></div>
                                    <small class="badge bg-secondary" style="font-size:0.7rem;"><t t-esc="app.state_field_name"/></small>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- 4. Logs / History Tab -->
                <div t-if="props.activeTab === 'logs'" class="tab-pane show active">
                    <h5 class="fw-bold mb-3">Customisation Log</h5>
                    <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 400px;">
                        <t t-foreach="props.logs" t-as="log" t-key="log.id">
                            <div class="list-group-item py-2 px-3 bg-light bg-opacity-25 d-flex justify-content-between align-items-center">
                                <div style="max-width: 75%;">
                                    <div class="fw-bold text-dark small" style="line-height: 1.2;"><t t-esc="log.name"/></div>
                                    <small class="text-muted" style="font-size:0.65rem;"><t t-esc="log.create_date"/></small>
                                </div>
                                <button class="btn btn-sm btn-outline-danger py-0 px-2 flex-shrink-0" t-on-click="() => props.onRevertLog(log.id)">Revert</button>
                            </div>
                        </t>
                        <div t-if="props.logs.length === 0" class="text-center text-muted py-5 small">
                            <p class="mb-0">No customisations logged for this model yet.</p>
                        </div>
                    </div>
                </div>

            </div>
        </aside>
    </t>
</templates>
