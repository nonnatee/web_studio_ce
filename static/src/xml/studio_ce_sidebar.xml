<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeSidebar" owl="1">
        <aside class="o_studio_ce_sidebar bg-white border-end d-flex flex-column flex-shrink-0 h-100 overflow-auto" style="width: 320px;">
            <!-- Sub-tabs Row (+ Add, View, Properties) -->
            <ul t-if="props.activeTab === 'views' || !['reports', 'automations', 'approvals', 'security', 'menu', 'logs'].includes(props.activeTab)"
                class="nav-sidebar-subtabs d-flex nav-fill flex-shrink-0 list-unstyled p-0 m-0 border-bottom">
                <li class="flex-grow-1 text-center">
                    <button class="nav-link w-100 border-0 bg-transparent py-2"
                            t-att-class="{ active: state.activeSubTab === 'add' }"
                            t-on-click="() => this.selectSubTab('add')">
                        + Add
                    </button>
                </li>
                <li class="flex-grow-1 text-center">
                    <button class="nav-link w-100 border-0 bg-transparent py-2"
                            t-att-class="{ active: state.activeSubTab === 'view' }"
                            t-on-click="() => this.selectSubTab('view')">
                        View
                    </button>
                </li>
                <li class="flex-grow-1 text-center">
                    <button class="nav-link w-100 border-0 bg-transparent py-2"
                            t-att-class="{ active: state.activeSubTab === 'properties' }"
                            t-att-disabled="!props.selectedField ? '1' : undefined"
                            t-on-click="() => this.selectSubTab('properties')">
                        Properties
                    </button>
                </li>
            </ul>

            <div class="tab-content p-3 flex-grow-1">
                
                <!-- 1. Fields Tab (Active in Views mode) -->
                <div t-if="props.activeTab === 'views' || !['reports', 'automations', 'approvals', 'security', 'menu', 'logs'].includes(props.activeTab)" class="tab-pane show active">
                    
                    <!-- Sub-panel A: Properties Tab -->
                    <t t-if="state.activeSubTab === 'properties' and props.selectedField">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-white">Properties</h5>
                            <button class="btn btn-sm btn-outline-light py-0 px-2" t-on-click="() => props.onDeselectField()">✕ Clear</button>
                        </div>

                        <t t-if="props.selectedField.ttype === 'properties'">
                            <PropertiesBuilder fieldName="props.selectedField.name" modelName="props.modelName"/>
                        </t>
                        <t t-elif="props.selectedField.ttype === 'button'">
                            <!-- Smart Button Label -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Button Label</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                       t-att-value="props.selectedField.field_description"
                                       t-on-change="(ev) => this.overrideProperty('string', ev.target.value)"/>
                            </div>
                            <!-- Smart Button Icon Selector -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Button Icon</label>
                                <select class="form-select form-select-sm bg-dark text-white border-secondary"
                                        t-att-value="props.selectedField.icon || 'fa-star'"
                                        t-on-change="(ev) => this.overrideProperty('icon', ev.target.value)">
                                    <option value="fa-star">⭐ Star (fa-star)</option>
                                    <option value="fa-tasks">📋 Tasks (fa-tasks)</option>
                                    <option value="fa-usd">💲 Currency (fa-usd)</option>
                                    <option value="fa-shopping-cart">🛒 Orders (fa-shopping-cart)</option>
                                    <option value="fa-envelope">✉️ Messages (fa-envelope)</option>
                                    <option value="fa-users">👥 Partners (fa-users)</option>
                                    <option value="fa-folder">📁 Records (fa-folder)</option>
                                </select>
                            </div>
                            <!-- Smart Button Action Target -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Target Window Action</label>
                                <select class="form-select form-select-sm bg-dark text-white border-secondary"
                                        t-att-value="props.selectedField.action_id || ''"
                                        t-on-change="(ev) => this.overrideProperty('name', ev.target.value)">
                                    <option value="">-- No Action / Custom --</option>
                                    <t t-foreach="state.windowActions || []" t-as="act" t-key="act.id">
                                        <option t-att-value="'%(' + act.id + ')d'" t-esc="act.name"/>
                                    </t>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">XPath Location</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" readonly="1"
                                       t-att-value="props.selectedField.name"/>
                            </div>
                            <button class="btn btn-sm btn-danger w-100 mt-3" t-on-click="removeFieldFromView">🗑️ Remove Smart Button</button>
                        </t>
                        <t t-elif="props.selectedField.ttype === 'group'">
                            <!-- Group Label Input -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Group Label</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                       t-att-value="props.selectedField.field_description"
                                       t-on-change="(ev) => this.overrideProperty('string', ev.target.value)"/>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">XPath Location</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" readonly="1"
                                       t-att-value="props.selectedField.name"/>
                            </div>
                            <button class="btn btn-sm btn-danger w-100 mt-3" t-on-click="removeFieldFromView">🗑️ Remove Group</button>
                        </t>
                        <t t-elif="props.selectedField.ttype === 'page'">
                            <!-- Page Label Input -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Page Label</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                       t-att-value="props.selectedField.field_description"
                                       t-on-change="(ev) => this.overrideProperty('string', ev.target.value)"/>
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">XPath Location</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" readonly="1"
                                       t-att-value="props.selectedField.name"/>
                            </div>
                            <button class="btn btn-sm btn-danger w-100 mt-3" t-on-click="removeFieldFromView">🗑️ Remove Page</button>
                        </t>
                        <t t-else="">
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Field Label</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                       t-att-value="props.selectedField.field_description"
                                       t-on-change="(ev) => this.updateProperty('field_description', ev.target.value)"/>
                            </div>

                            <!-- Basic Attributes -->
                            <div class="d-flex flex-column gap-2 mb-3">
                                <div class="form-check form-switch">
                                    <input type="checkbox" class="form-check-input" id="fieldReq"
                                           t-att-checked="props.selectedField.required"
                                           t-on-change="(ev) => this.updateProperty('required', ev.target.checked)"/>
                                    <label class="form-check-label text-white small" for="fieldReq">Required</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input type="checkbox" class="form-check-input" id="fieldRead"
                                           t-att-checked="props.selectedField.readonly"
                                           t-on-change="(ev) => this.updateProperty('readonly', ev.target.checked)"/>
                                    <label class="form-check-label text-white small" for="fieldRead">Read Only</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input type="checkbox" class="form-check-input" id="fieldInvis"
                                           t-att-checked="props.selectedField.invisible"
                                           t-on-change="(ev) => this.updateProperty('invisible', ev.target.checked)"/>
                                    <label class="form-check-label text-white small" for="fieldInvis">Invisible</label>
                                </div>
                            </div>

                            <!-- Advanced/Calculated fields -->
                            <div class="mb-3 border-top pt-3">
                                <div class="form-check form-switch mb-2">
                                    <input type="checkbox" class="form-check-input" id="fieldCompute"
                                           t-att-checked="!!props.selectedField.compute"
                                           t-on-change="(ev) => this.updateProperty('compute', ev.target.checked ? 'result = 42' : false)"/>
                                    <label class="form-check-label text-white small" for="fieldCompute">Calculated Field (Python)</label>
                                </div>
                                <div t-if="props.selectedField.compute" class="mb-2">
                                    <label class="form-label text-secondary small fw-bold">Dependencies</label>
                                    <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                           placeholder="e.g. x_field1,x_field2"
                                           t-att-value="props.selectedField.depends"
                                           t-on-change="(ev) => this.updateProperty('depends', ev.target.value)"/>
                                </div>
                                <div t-if="props.selectedField.compute" class="mb-2">
                                    <label class="form-label text-secondary small fw-bold">Python Code</label>
                                    <textarea class="form-control form-control-sm font-monospace bg-dark text-white border-secondary" rows="5" style="font-size:0.75rem;"
                                              t-att-value="props.selectedField.compute"
                                              t-on-change="(ev) => this.updateProperty('compute', ev.target.value)"/>
                                </div>
                            </div>

                            <!-- Relational Link -->
                            <div t-if="['many2one', 'one2many', 'many2many'].includes(props.selectedField.ttype)" class="mb-3 border-top pt-3">
                                <label class="form-label text-secondary small fw-bold">Related Model</label>
                                <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary"
                                       placeholder="e.g. res.partner"
                                       t-att-value="props.selectedField.relation"
                                       t-on-change="(ev) => this.updateProperty('relation', ev.target.value)"/>
                            </div>

                            <!-- Selection Options -->
                            <div t-if="props.selectedField.ttype === 'selection'" class="mb-3 border-top pt-3">
                                <label class="form-label text-secondary small fw-bold">Selection Options</label>
                                <div class="list-group mb-2 border rounded">
                                    <t t-foreach="props.selectedField.selectionOptions || []" t-as="option" t-key="option[0]">
                                        <div class="list-group-item d-flex justify-content-between align-items-center py-1 px-2 small bg-dark border-secondary text-white">
                                            <span><strong t-esc="option[0]"/>: <t t-esc="option[1]"/></span>
                                            <button class="btn btn-sm text-danger p-0 border-0 bg-transparent font-weight-bold" t-on-click="() => this.removeSelectionOption(option[0])">✕</button>
                                        </div>
                                    </t>
                                </div>
                                <div class="input-group input-group-sm mb-1">
                                    <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Key" t-model="state.newOptionKey"/>
                                    <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Label" t-model="state.newOptionValue"/>
                                    <button class="btn btn-primary" t-on-click="addSelectionOption">+</button>
                                </div>
                            </div>

                            <button class="btn btn-sm btn-danger w-100 mt-3" t-on-click="removeFieldFromView">🗑️ Remove Field</button>
                        </t>
                    </t>

                    <!-- Sub-panel B: View Settings Tab -->
                    <t t-elif="state.activeSubTab === 'view'">
                        <h5 class="fw-bold mb-3">View Settings</h5>
                        <div class="mb-3">
                            <label class="form-label text-secondary small fw-bold">Active View Name</label>
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" readonly="1"
                                   t-att-value="props.views?.length ? props.views[0].name : 'Form View'"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small fw-bold">View Type</label>
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" readonly="1"
                                   t-att-value="props.views?.length ? props.views[0].type.toUpperCase() : 'FORM'"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-secondary small fw-bold">Target Model</label>
                            <input type="text" class="form-control form-control-sm bg-dark text-white border-secondary" readonly="1"
                                   t-att-value="props.modelName"/>
                        </div>
                    </t>

                    <!-- Sub-panel C: Add Components & Fields Tab (Default) -->
                    <t t-else="">
                        <h5 class="fw-bold mb-2">Components</h5>
                        <div class="o_studio_ce_new_fields_grid mb-4">
                            <button class="btn-field-card" draggable="true" t-on-dragstart="onDragStartNewGroup">
                                <span class="field-card-icon">🔳</span>
                                <span>Column</span>
                            </button>
                            <button class="btn-field-card" disabled="1" style="opacity: 0.65;">
                                <span class="field-card-icon">🗂️</span>
                                <span>Tabs</span>
                            </button>
                        </div>

                        <h5 class="fw-bold mb-2">New Fields</h5>
                        <div class="o_studio_ce_new_fields_grid mb-4">
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'char')" t-on-click="() => props.onAddField('char', 'Text Field')">
                                <span class="field-card-icon">Ab</span>
                                <span>Text</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'html')" t-on-click="() => props.onAddField('html', 'Multiline Text Field')">
                                <span class="field-card-icon">✎</span>
                                <span>Multiline Text</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'integer')" t-on-click="() => props.onAddField('integer', 'Integer Field')">
                                <span class="field-card-icon">N⁺</span>
                                <span>Integer</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'float')" t-on-click="() => props.onAddField('float', 'Decimal Field')">
                                <span class="field-card-icon">1.5</span>
                                <span>Decimal</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'html')" t-on-click="() => props.onAddField('html', 'HTML Area')">
                                <span class="field-card-icon">&lt;/&gt;</span>
                                <span>HTML</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'monetary')" t-on-click="() => props.onAddField('monetary', 'Monetary Field')">
                                <span class="field-card-icon">€</span>
                                <span>Monetary</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'date')" t-on-click="() => props.onAddField('date', 'Date Field')">
                                <span class="field-card-icon">21</span>
                                <span>Date</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'datetime')" t-on-click="() => props.onAddField('datetime', 'Datetime Field')">
                                <span class="field-card-icon">🕒</span>
                                <span>Datetime</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'boolean')" t-on-click="() => props.onAddField('boolean', 'Checkbox Field')">
                                <span class="field-card-icon">✓</span>
                                <span>CheckBox</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'selection')" t-on-click="() => props.onAddField('selection', 'Selection Field')">
                                <span class="field-card-icon">⏷</span>
                                <span>Selection</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'binary')" t-on-click="() => props.onAddField('binary', 'File Field')">
                                <span class="field-card-icon">📄</span>
                                <span>File</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'many2one')" t-on-click="() => props.onAddField('many2one', 'Many2one Relation')">
                                <span class="field-card-icon">⚬──⚬</span>
                                <span>Many2One</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="(ev) => this.onDragStartNewField(ev, 'many2many')" t-on-click="() => props.onAddField('many2many', 'Many2many Tags')">
                                <span class="field-card-icon">🏷️</span>
                                <span>Many2Many</span>
                            </button>
                            <button class="btn-field-card" draggable="true" t-on-dragstart="onDragStartNewSmartButton">
                                <span class="field-card-icon">⭐</span>
                                <span>Smart Button</span>
                            </button>
                        </div>

                        <h5 class="fw-bold mb-2">Existing Fields</h5>
                        
                        <!-- Rich Search & Filters -->
                        <div class="mb-3">
                            <input type="text" class="form-control form-control-sm mb-2" placeholder="🔍 Search existing fields..." t-model="state.searchQuery"/>
                            <div class="d-flex flex-wrap gap-1 mb-2">
                                <button class="badge border-0 py-1 px-2 cursor-pointer transition-all"
                                        t-att-class="state.activeFilter === 'all' ? 'bg-primary text-white' : 'bg-light text-secondary'"
                                        t-on-click="() => this.state.activeFilter = 'all'">All</button>
                                <button class="badge border-0 py-1 px-2 cursor-pointer transition-all"
                                        t-att-class="state.activeFilter === 'text' ? 'bg-primary text-white' : 'bg-light text-secondary'"
                                        t-on-click="() => this.state.activeFilter = 'text'">Text</button>
                                <button class="badge border-0 py-1 px-2 cursor-pointer transition-all"
                                        t-att-class="state.activeFilter === 'number' ? 'bg-primary text-white' : 'bg-light text-secondary'"
                                        t-on-click="() => this.state.activeFilter = 'number'">Numeric</button>
                                <button class="badge border-0 py-1 px-2 cursor-pointer transition-all"
                                        t-att-class="state.activeFilter === 'relation' ? 'bg-primary text-white' : 'bg-light text-secondary'"
                                        t-on-click="() => this.state.activeFilter = 'relation'">Relation</button>
                                <button class="badge border-0 py-1 px-2 cursor-pointer transition-all"
                                        t-att-class="state.activeFilter === 'other' ? 'bg-primary text-white' : 'bg-light text-secondary'"
                                        t-on-click="() => this.state.activeFilter = 'other'">Other</button>
                            </div>
                        </div>

                        <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 250px;">
                            <t t-foreach="filteredFields" t-as="field" t-key="field.id">
                                <div class="list-group-item d-flex justify-content-between align-items-center py-2 px-3">
                                    <div class="d-flex align-items-center gap-2 text-truncate me-2">
                                        <span class="o_drag_handle text-muted cursor-grab" 
                                              draggable="true" 
                                              t-on-dragstart="(ev) => this.onDragStartExistingField(ev, field.name, field.field_description)">⋮⋮</span>
                                        <div class="text-truncate cursor-pointer" t-on-click="() => props.onSelectField(field)">
                                            <div class="fw-bold text-dark text-truncate small"><t t-esc="field.field_description"/></div>
                                            <small class="text-muted font-monospace" style="font-size:0.75rem;"><t t-esc="field.name"/></small>
                                        </div>
                                    </div>
                                    <button class="btn btn-sm btn-link py-0 px-1 text-primary flex-shrink-0" 
                                            t-if="props.views.length > 0"
                                            t-on-click="() => props.onAddFieldToView(props.views[0].id, field.name)">
                                        Add
                                    </button>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- 3. Automations Tab -->
                <div t-if="props.activeTab === 'automations'" class="tab-pane show active">
                    <t t-if="state.selectedRule">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-dark">Rule Properties</h5>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-2" t-on-click="() => this.deselectRule()">✕ Back</button>
                        </div>
                        <AutomationEditor rule="state.selectedRule" fields="props.fields" onRuleUpdated.bind="onRuleUpdated"/>
                    </t>
                    <t t-else="">
                        <h5 class="fw-bold mb-3">Automated Actions</h5>
                        <button class="btn btn-primary btn-sm w-100 mb-3" t-on-click="props.onAddAutomation">
                            Create Rule
                        </button>
                        <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 350px;">
                            <t t-foreach="props.automations" t-as="auto" t-key="auto.id">
                                <div class="list-group-item list-group-item-action py-2 px-3 cursor-pointer" t-on-click="() => this.selectRule(auto)">
                                    <div class="fw-bold text-dark small"><t t-esc="auto.name"/></div>
                                    <small class="badge bg-secondary" style="font-size:0.7rem;"><t t-esc="auto.trigger"/></small>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- 3.5. Approvals Tab -->
                <div t-if="props.activeTab === 'approvals'" class="tab-pane show active">
                    <t t-if="state.selectedApproval">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="fw-bold mb-0 text-dark">Approval Properties</h5>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-2" t-on-click="() => this.deselectApproval()">✕ Back</button>
                        </div>
                        <ApprovalEditor approval="state.selectedApproval" groups="props.groups" modelName="props.modelName" onApprovalUpdated.bind="onApprovalUpdated"/>
                    </t>
                    <t t-else="">
                        <h5 class="fw-bold mb-3">Approval Workflows</h5>
                        <button class="btn btn-primary btn-sm w-100 mb-3" t-on-click="props.onAddApproval">
                            Create Workflow
                        </button>
                        <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 350px;">
                            <t t-foreach="props.approvals || []" t-as="app" t-key="app.id">
                                <div class="list-group-item list-group-item-action py-2 px-3 cursor-pointer" t-on-click="() => this.selectApproval(app)">
                                    <div class="fw-bold text-dark small"><t t-esc="app.name"/></div>
                                    <small class="badge bg-secondary" style="font-size:0.7rem;"><t t-esc="app.state_field_name"/></small>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <!-- 4. Logs / History Tab -->
                <div t-if="props.activeTab === 'logs'" class="tab-pane show active">
                    <h5 class="fw-bold mb-3">Customisation Log</h5>
                    <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 400px;">
                        <t t-foreach="props.logs" t-as="log" t-key="log.id">
                            <div class="list-group-item py-2 px-3 bg-light bg-opacity-25 d-flex justify-content-between align-items-center">
                                <div style="max-width: 75%;">
                                    <div class="fw-bold text-dark small" style="line-height: 1.2;"><t t-esc="log.name"/></div>
                                    <small class="text-muted" style="font-size:0.65rem;"><t t-esc="log.create_date"/></small>
                                </div>
                                <button class="btn btn-sm btn-outline-danger py-0 px-2 flex-shrink-0" t-on-click="() => props.onRevertLog(log.id)">Revert</button>
                            </div>
                        </t>
                        <div t-if="props.logs.length === 0" class="text-center text-muted py-5 small">
                            <p class="mb-0">No customisations logged for this model yet.</p>
                        </div>
                    </div>
                </div>

                <!-- 5. Reports Tab -->
                <div t-if="props.activeTab === 'reports'" class="tab-pane show active">
                    <h5 class="fw-bold mb-3">Model Reports</h5>
                    <button class="btn btn-primary btn-sm w-100 mb-3" t-on-click="createNewReport">
                        Create Report
                    </button>
                    <div class="list-group list-group-flush border rounded overflow-auto" style="max-height: 350px;">
                        <t t-foreach="state.reports || []" t-as="rep" t-key="rep.id">
                            <div class="list-group-item list-group-item-action py-2 px-3 cursor-pointer"
                                 t-att-class="state.selectedReportId === rep.id ? 'bg-primary bg-opacity-10 fw-bold' : ''"
                                 t-on-click="() => this.selectReport(rep)">
                                <div class="fw-bold text-dark small"><t t-esc="rep.name"/></div>
                                <div class="text-muted font-monospace" style="font-size:0.7rem;"><t t-esc="rep.report_name"/></div>
                            </div>
                        </t>
                        <div t-if="!state.reports or state.reports.length === 0" class="text-center text-muted py-5 small">
                            No reports configured for this model.
                        </div>
                    </div>
                </div>

            </div>
        </aside>
    </t>
</templates>
