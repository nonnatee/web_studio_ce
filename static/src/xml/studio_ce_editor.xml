<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeEditor" owl="1">
        <div class="o_studio_ce_editor container-fluid d-flex flex-column h-100 bg-light p-0">
            <!-- Top Navbar -->
            <header class="navbar navbar-dark bg-dark text-white px-3 py-2 flex-shrink-0 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                    <span class="navbar-brand fw-bold mb-0 h4">Odoo Studio <span class="text-primary">CE</span></span>
                    <span class="badge bg-secondary ms-3"><t t-esc="state.model"/></span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-outline-primary btn-sm d-flex align-items-center gap-1" t-on-click="openAppCreator">
                        <span>🆕</span> Create App
                    </button>
                    <button class="btn btn-outline-light btn-sm o_studio_ce_help_btn d-flex align-items-center gap-1" t-on-click="openDocs">
                        <span>📖</span> Help
                    </button>
                    <button class="btn btn-outline-danger btn-sm" t-on-click="closeStudio">Close Studio</button>
                </div>
            </header>

            <!-- Main Workspace -->
            <div class="d-flex flex-grow-1 w-100 overflow-hidden">
                <StudioCeSidebar activeTab="state.activeTab"
                                 fields="state.fields"
                                 views="state.views"
                                 automations="state.automations"
                                 selectedField="state.selectedField"
                                 modelName="state.model"
                                 logs="state.logs"
                                 approvals="state.approvals"
                                 groups="state.groups"
                                 onTabChange.bind="onTabChange"
                                 onSelectField.bind="onSelectField"
                                 onDeselectField.bind="onDeselectField"
                                 onFieldUpdate.bind="onFieldUpdate"
                                 onAddField.bind="addCustomField"
                                 onAddFieldToView.bind="addFieldToView"
                                 onAddAutomation.bind="addAutomationRule"
                                 onRuleReload.bind="loadStudioContext"
                                 onAddApproval.bind="addApprovalWorkflow"
                                 onApprovalReload.bind="loadStudioContext"
                                 onRevertLog.bind="revertLog"
                                 onOverrideProperty.bind="overrideViewFieldProperty"
                                 onViewChange.bind="onViewChange"
                                 onDeleteNode.bind="deleteNodeInView"
                                 onSelectReport.bind="onSelectReport"/>

                <!-- Central Canvas Overlay -->
                <main class="flex-grow-1 bg-light p-4 overflow-auto position-relative">
                    <div t-if="state.loading" class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex justify-content-center align-items-center" style="z-index: 1050;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>

                    <t t-if="state.activeTab === 'security'">
                        <SecurityEditor model="state.model"/>
                    </t>
                    <t t-elif="state.activeTab === 'reports'">
                        <ReportEditor model="state.model" report="state.selectedReport" onBack.bind="onBackToReports"/>
                    </t>
                    <t t-else="">
                        <StudioCeCanvas onRegister.bind="onRegisterCanvas"
                                         model="state.model"
                                         view="state.views.find(v => v.id === state.viewId) || state.views[0]"
                                         views="state.views"
                                         fields="state.fields"
                                         selectedField="state.selectedField"
                                         onSelectField.bind="onSelectField"
                                         onToggleVisibility.bind="toggleFieldVisibility"
                                         onInsertField.bind="insertFieldIntoView"
                                         onInsertNewField.bind="insertNewFieldIntoView"
                                         onInsertNewGroup.bind="insertNewGroupIntoView"
                                         onMoveNode.bind="moveNodeInView"
                                         onDeleteNode.bind="deleteNodeInView"
                                         onOverrideProperty.bind="overrideViewFieldProperty"
                                         onViewChange.bind="onViewChange"/>
                    </t>
                </main>
            </div>

            <!-- New Field Creation Modal -->
            <div t-if="state.showFieldCreateModal" class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1" role="dialog" style="z-index: 1070;">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content shadow-lg border-primary">
                        <div class="modal-header bg-primary text-white py-3">
                            <h5 class="modal-title fw-bold">✨ Create New Field</h5>
                            <button type="button" class="btn-close btn-close-white" t-on-click="closeFieldCreateModal"></button>
                        </div>
                        <div class="modal-body py-4">
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Field Label</label>
                                <input type="text" class="form-control form-control-sm" placeholder="e.g. My Custom Text" 
                                       t-model="state.fieldCreateLabel"
                                       t-on-input="onFieldCreateLabelInput"/>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Technical Name</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text font-monospace bg-light" style="font-size: 0.85rem;">x_studio_</span>
                                    <input type="text" class="form-control font-monospace" placeholder="my_custom_text" 
                                           t-model="state.fieldCreateTechnicalName"
                                           t-on-input="onFieldCreateTechnicalNameInput"
                                           style="font-size: 0.85rem;"/>
                                </div>
                                <div class="form-text text-muted small mt-1" style="font-size: 0.72rem;">
                                    Full database name: <span class="font-monospace">x_studio_<t t-esc="state.fieldCreateTechnicalName || ''"/></span>
                                </div>
                            </div>
                            
                            <div t-if="state.fieldCreateError" class="alert alert-danger py-2 small mb-0 mt-3" style="font-size: 0.75rem;">
                                ⚠️ <t t-esc="state.fieldCreateError"/>
                            </div>
                        </div>
                        <div class="modal-footer bg-light py-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="closeFieldCreateModal">Cancel</button>
                            <button type="button" class="btn btn-sm btn-primary px-3" t-on-click="submitFieldCreate">Create Field</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Documentation Panel Overlay -->
            <StudioCeDocsPanel t-if="state.showDocs" onClose.bind="closeDocs"/>

            <!-- App Creator Dialog Overlay -->
            <AppCreator t-if="state.showAppCreator" onClose.bind="closeAppCreator" onAppCreated.bind="onAppCreated"/>
        </div>
    </t>
</templates>
