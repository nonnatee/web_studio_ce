<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeEditor" owl="1">
        <div class="o_studio_ce_editor container-fluid d-flex flex-column h-100 bg-light p-0">
            <!-- Google Fonts Loader -->
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;display=swap"/>

            <!-- Top Navbar -->
            <header class="navbar-studio text-white px-3 py-2 flex-shrink-0 d-flex justify-content-between align-items-center">
                <!-- Left: Dynamic Breadcrumb -->
                <div class="d-flex align-items-center text-uppercase font-weight-bold" style="font-family: 'Outfit', sans-serif; font-size: 0.85rem; letter-spacing: 0.05em; color: rgba(255, 255, 255, 0.85);">
                    <span class="text-muted" style="color: rgba(255, 255, 255, 0.5) !important;">Views</span>
                    <span class="mx-2 text-white-50">></span>
                    <span class="text-white fw-bold"><t t-esc="activeViewType"/></span>
                    <span class="badge bg-white bg-opacity-10 text-white-50 ms-3 font-monospace" style="font-size: 0.65rem; text-transform: none;"><t t-esc="state.model"/></span>
                </div>

                <!-- Center: Undo/Redo Controls -->
                <div class="d-flex align-items-center gap-2 text-uppercase" style="font-family: 'Outfit', sans-serif; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.03em;">
                    <button class="btn btn-link text-white text-decoration-none p-0 d-flex align-items-center gap-1 opacity-75 hover-opacity-100 border-0 bg-transparent" t-on-click="undoLastChange" style="font-size:0.78rem;">
                        <span>↶</span> Undo
                    </button>
                    <span class="text-muted mx-1" style="opacity: 0.3;">|</span>
                    <button class="btn btn-link text-white text-decoration-none p-0 d-flex align-items-center gap-1 opacity-75 hover-opacity-100 border-0 bg-transparent" t-on-click="redoLastChange" style="font-size:0.78rem;">
                        <span>↷</span> Redo
                    </button>
                </div>

                <!-- Center: Navigation Tabs -->
                <ul class="nav-studio-tabs">
                    <li class="nav-item">
                        <button class="nav-link border-0 bg-transparent" 
                                t-att-class="{ active: state.activeTab === 'views' || !['reports', 'automations', 'approvals', 'security', 'menu'].includes(state.activeTab) }"
                                t-on-click="() => this.onTabChange('views')">
                            <span>👁️</span> Views
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link border-0 bg-transparent" 
                                t-att-class="{ active: state.activeTab === 'reports' }"
                                t-on-click="() => this.onTabChange('reports')">
                            <span>📄</span> Reports
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link border-0 bg-transparent" 
                                t-att-class="{ active: state.activeTab === 'automations' }"
                                t-on-click="() => this.onTabChange('automations')">
                            <span>⚡</span> Rules
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link border-0 bg-transparent" 
                                t-att-class="{ active: state.activeTab === 'approvals' }"
                                t-on-click="() => this.onTabChange('approvals')">
                            <span>🛡️</span> Approvals
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link border-0 bg-transparent" 
                                t-att-class="{ active: state.activeTab === 'security' }"
                                t-on-click="() => this.onTabChange('security')">
                            <span>🔒</span> Security
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link border-0 bg-transparent" 
                                t-att-class="{ active: state.activeTab === 'menu' }"
                                t-on-click="() => this.onTabChange('menu')">
                            <span>🌿</span> Menu
                        </button>
                    </li>
                </ul>

                <!-- Right: Utility Actions -->
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-sm btn-info text-white d-flex align-items-center gap-1" t-on-click="openAppCreator" style="font-size:0.8rem; font-weight:500;">
                        <span>🆕</span> Create App
                    </button>
                    <button class="btn btn-sm btn-outline-light d-flex align-items-center gap-1" t-on-click="openDocs" style="font-size:0.8rem; font-weight:500;">
                        <span>📖</span> Help
                    </button>
                    <button class="btn btn-sm btn-danger px-3" t-on-click="closeStudio" style="font-size:0.8rem; font-weight:600;">Close Studio</button>
                </div>
            </header>

            <!-- Main Workspace -->
            <div class="d-flex flex-grow-1 w-100 overflow-hidden">
                <StudioCeSidebar activeTab="state.activeTab"
                                 fields="state.fields"
                                 views="state.views"
                                 automations="state.automations"
                                 selectedField="state.selectedField"
                                 modelName="state.model"
                                 logs="state.logs"
                                 approvals="state.approvals"
                                 groups="state.groups"
                                 onTabChange.bind="onTabChange"
                                 onSelectField.bind="onSelectField"
                                 onDeselectField.bind="onDeselectField"
                                 onFieldUpdate.bind="onFieldUpdate"
                                 onAddField.bind="addCustomField"
                                 onAddFieldToView.bind="addFieldToView"
                                 onAddAutomation.bind="addAutomationRule"
                                 onRuleReload.bind="loadStudioContext"
                                 onAddApproval.bind="addApprovalWorkflow"
                                 onApprovalReload.bind="loadStudioContext"
                                 onRevertLog.bind="revertLog"
                                 onOverrideProperty.bind="overrideViewFieldProperty"
                                 onViewChange.bind="onViewChange"
                                 onDeleteNode.bind="deleteNodeInView"
                                 onSelectReport.bind="onSelectReport"/>

                <!-- Central Canvas Overlay -->
                <main class="flex-grow-1 bg-light p-4 overflow-auto position-relative">
                    <div t-if="state.loading" class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex justify-content-center align-items-center" style="z-index: 1050;">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>

                    <t t-if="state.activeTab === 'security'">
                        <SecurityEditor model="state.model"/>
                    </t>
                    <t t-elif="state.activeTab === 'menu'">
                        <MenuEditor/>
                    </t>
                    <t t-elif="state.activeTab === 'reports'">
                        <ReportEditor model="state.model" report="state.selectedReport" onBack.bind="onBackToReports"/>
                    </t>
                    <t t-else="">
                        <StudioCeCanvas onRegister.bind="onRegisterCanvas"
                                         model="state.model"
                                         view="state.views.find(v => v.id === state.viewId) || state.views[0]"
                                         views="state.views"
                                         fields="state.fields"
                                         selectedField="state.selectedField"
                                         onSelectField.bind="onSelectField"
                                         onToggleVisibility.bind="toggleFieldVisibility"
                                         onInsertField.bind="insertFieldIntoView"
                                         onInsertNewField.bind="insertNewFieldIntoView"
                                         onInsertNewGroup.bind="insertNewGroupIntoView"
                                         onMoveNode.bind="moveNodeInView"
                                         onDeleteNode.bind="deleteNodeInView"
                                         onOverrideProperty.bind="overrideViewFieldProperty"
                                         onViewChange.bind="onViewChange"/>
                    </t>
                </main>
            </div>

            <!-- New Field Creation Modal -->
            <div t-if="state.showFieldCreateModal" class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1" role="dialog" style="z-index: 1070;">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content shadow-lg border-primary">
                        <div class="modal-header bg-primary text-white py-3">
                            <h5 class="modal-title fw-bold">✨ Create New Field</h5>
                            <button type="button" class="btn-close btn-close-white" t-on-click="closeFieldCreateModal"></button>
                        </div>
                        <div class="modal-body py-4">
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Field Label</label>
                                <input type="text" class="form-control form-control-sm" placeholder="e.g. My Custom Text" 
                                       t-model="state.fieldCreateLabel"
                                       t-on-input="onFieldCreateLabelInput"/>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Technical Name</label>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text font-monospace bg-light" style="font-size: 0.85rem;">x_studio_</span>
                                    <input type="text" class="form-control font-monospace" placeholder="my_custom_text" 
                                           t-model="state.fieldCreateTechnicalName"
                                           t-on-input="onFieldCreateTechnicalNameInput"
                                           style="font-size: 0.85rem;"/>
                                </div>
                                <div class="form-text text-muted small mt-1" style="font-size: 0.72rem;">
                                    Full database name: <span class="font-monospace">x_studio_<t t-esc="state.fieldCreateTechnicalName || ''"/></span>
                                </div>
                            </div>
                            
                            <div t-if="state.fieldCreateError" class="alert alert-danger py-2 small mb-0 mt-3" style="font-size: 0.75rem;">
                                ⚠️ <t t-esc="state.fieldCreateError"/>
                            </div>
                        </div>
                        <div class="modal-footer bg-light py-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="closeFieldCreateModal">Cancel</button>
                            <button type="button" class="btn btn-sm btn-primary px-3" t-on-click="submitFieldCreate">Create Field</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Documentation Panel Overlay -->
            <StudioCeDocsPanel t-if="state.showDocs" onClose.bind="closeDocs"/>

            <!-- App Creator Dialog Overlay -->
            <AppCreator t-if="state.showAppCreator" onClose.bind="closeAppCreator" onAppCreated.bind="onAppCreated"/>
        </div>
    </t>
</templates>
