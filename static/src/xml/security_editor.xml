<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.SecurityEditor" owl="1">
        <div class="o_studio_ce_security_editor container-fluid py-3 bg-white h-100 d-flex flex-column">
            
            <!-- Editor Title/Actions -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Access Rights Matrix</h5>
                    <p class="text-muted small mb-0">Manage security group permissions for the current model.</p>
                </div>
                <button class="btn btn-primary btn-sm d-flex align-items-center gap-1" 
                        t-on-click="saveChanges" 
                        t-att-disabled="state.saving">
                    <span t-if="state.saving" class="spinner-border spinner-border-sm" role="status"></span>
                    Save Permissions
                </button>
            </div>

            <!-- Loader -->
            <div t-if="state.loading" class="d-flex justify-content-center align-items-center flex-grow-1">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <t t-else="">
                <!-- Add Group Dropdown Control -->
                <div class="row align-items-center mb-4 flex-shrink-0 bg-light p-3 rounded mx-0">
                    <div class="col-md-6 d-flex align-items-center gap-2">
                        <label class="fw-bold text-secondary small mb-0 flex-shrink-0">Add Group to Matrix</label>
                        <select class="form-select form-select-sm" t-model="state.selectedGroupId">
                            <option value="">-- Choose User Group --</option>
                            <t t-foreach="state.availableGroups" t-as="group" t-key="group.id">
                                <option t-att-value="group.id"><t t-esc="group.name"/></option>
                            </t>
                        </select>
                        <button class="btn btn-secondary btn-sm flex-shrink-0" 
                                t-on-click="addGroupToMatrix"
                                t-att-disabled="!state.selectedGroupId">
                            Add Group
                        </button>
                    </div>
                </div>

                <!-- Matrix Table -->
                <div class="flex-grow-1 overflow-auto border rounded bg-white">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th scope="col" class="py-3 px-4">User Group</th>
                                <th scope="col" class="text-center py-3">Read (perm_read)</th>
                                <th scope="col" class="text-center py-3">Write (perm_write)</th>
                                <th scope="col" class="text-center py-3">Create (perm_create)</th>
                                <th scope="col" class="text-center py-3">Delete (perm_unlink)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.acls" t-as="acl" t-key="acl.group_id or 'global'">
                                <tr>
                                    <td class="align-middle fw-bold text-dark py-3 px-4">
                                        <t t-esc="acl.group_name"/>
                                    </td>
                                    <td class="text-center align-middle py-3">
                                        <input type="checkbox" class="form-check-input" t-model="acl.read"/>
                                    </td>
                                    <td class="text-center align-middle py-3">
                                        <input type="checkbox" class="form-check-input" t-model="acl.write"/>
                                    </td>
                                    <td class="text-center align-middle py-3">
                                        <input type="checkbox" class="form-check-input" t-model="acl.create"/>
                                    </td>
                                    <td class="text-center align-middle py-3">
                                        <input type="checkbox" class="form-check-input" t-model="acl.unlink"/>
                                    </td>
                                </tr>
                            </t>
                            
                            <tr t-if="state.acls.length === 0">
                                <td colspan="5" class="text-center text-muted py-5">
                                    <div style="font-size: 2rem;">🔒</div>
                                    <p class="mb-0 small">No access rules set. The model is globally accessible to all internal users.</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
            
        </div>
    </t>
</templates>
