<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.SecurityEditor" owl="1">
        <div class="o_studio_ce_security_editor container-fluid py-3 bg-white h-100 d-flex flex-column overflow-auto">
            
            <!-- Editor Title/Actions -->
            <div class="d-flex justify-content-between align-items-center mb-3 flex-shrink-0">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Access Control &amp; Record Rules</h5>
                    <p class="text-muted small mb-0">Manage security permissions and row-level record rules for the current model.</p>
                </div>
                <button class="btn btn-primary btn-sm d-flex align-items-center gap-1" 
                        t-on-click="saveChanges" 
                        t-att-disabled="state.saving">
                    <span t-if="state.saving" class="spinner-border spinner-border-sm" role="status"></span>
                    Save ACL Matrix
                </button>
            </div>

            <!-- Loader -->
            <div t-if="state.loading" class="d-flex justify-content-center align-items-center flex-grow-1">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <t t-else="">
                <!-- Rule Edit Form Panel -->
                <div t-if="state.selectedRule" class="card p-3 mb-4 border shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                        <span class="fw-bold text-dark"><t t-esc="state.ruleForm.id ? '✏️ Edit Record Rule' : '➕ New Record Rule'"/></span>
                        <button class="btn btn-sm btn-link text-secondary p-0" t-on-click="cancelRuleEdit">Cancel</button>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Rule Name</label>
                        <input type="text" class="form-control form-control-sm" t-model="state.ruleForm.name"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Domain Force (Python Expression)</label>
                        <textarea class="form-control form-control-sm font-monospace" rows="2" style="font-size:0.75rem;" t-model="state.ruleForm.domain_force"/>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-3 text-center">
                            <label class="d-block text-secondary small fw-bold">Read</label>
                            <input type="checkbox" class="form-check-input" t-model="state.ruleForm.perm_read"/>
                        </div>
                        <div class="col-3 text-center">
                            <label class="d-block text-secondary small fw-bold">Write</label>
                            <input type="checkbox" class="form-check-input" t-model="state.ruleForm.perm_write"/>
                        </div>
                        <div class="col-3 text-center">
                            <label class="d-block text-secondary small fw-bold">Create</label>
                            <input type="checkbox" class="form-check-input" t-model="state.ruleForm.perm_create"/>
                        </div>
                        <div class="col-3 text-center">
                            <label class="d-block text-secondary small fw-bold">Delete</label>
                            <input type="checkbox" class="form-check-input" t-model="state.ruleForm.perm_unlink"/>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary small fw-bold">Apply to Groups</label>
                        <div class="border rounded p-2 overflow-auto bg-light" style="max-height: 120px;">
                            <t t-foreach="state.allGroups" t-as="g" t-key="g.id">
                                <div class="form-check small py-0 my-0">
                                    <input type="checkbox" class="form-check-input" t-att-id="'rg_' + g.id"
                                           t-att-checked="state.ruleForm.group_ids.includes(g.id)"
                                           t-on-change="() => this.toggleGroupInRule(g.id)"/>
                                    <label class="form-check-label text-dark" t-att-for="'rg_' + g.id">
                                        <t t-esc="g.name || g.display_name"/>
                                    </label>
                                </div>
                            </t>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-sm btn-outline-danger" t-if="state.ruleForm.id" t-on-click="() => this.deleteRule(state.ruleForm.id)">🗑️ Delete Rule</button>
                        <button class="btn btn-sm btn-success" t-on-click="saveRule">Save Rule</button>
                    </div>
                </div>

                <!-- Add Group Dropdown Control -->
                <div class="row align-items-center mb-4 flex-shrink-0 bg-light p-3 rounded mx-0">
                    <div class="col-md-6 d-flex align-items-center gap-2">
                        <label class="fw-bold text-secondary small mb-0 flex-shrink-0">Add Group to Matrix</label>
                        <select class="form-select form-select-sm" t-model="state.selectedGroupId">
                            <option value="">-- Choose User Group --</option>
                            <t t-foreach="state.availableGroups" t-as="group" t-key="group.id">
                                <option t-att-value="group.id"><t t-esc="group.name || group.display_name"/></option>
                            </t>
                        </select>
                        <button class="btn btn-secondary btn-sm flex-shrink-0" 
                                t-on-click="addGroupToMatrix"
                                t-att-disabled="!state.selectedGroupId">
                            Add Group
                        </button>
                    </div>
                </div>

                <!-- Section: Access Control List Matrix -->
                <div class="border rounded bg-white mb-4 overflow-auto" style="max-height: 250px;">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark sticky-top">
                            <tr>
                                <th scope="col" class="py-2 px-3 small">User Group</th>
                                <th scope="col" class="text-center py-2 small">Read</th>
                                <th scope="col" class="text-center py-2 small">Write</th>
                                <th scope="col" class="text-center py-2 small">Create</th>
                                <th scope="col" class="text-center py-2 small">Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.acls" t-as="acl" t-key="acl.group_id or 'global'">
                                <tr>
                                    <td class="align-middle fw-bold text-dark py-2 px-3 small">
                                        <t t-esc="acl.group_name"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <input type="checkbox" class="form-check-input" t-model="acl.read"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <input type="checkbox" class="form-check-input" t-model="acl.write"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <input type="checkbox" class="form-check-input" t-model="acl.create"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <input type="checkbox" class="form-check-input" t-model="acl.unlink"/>
                                    </td>
                                </tr>
                            </t>
                            <tr t-if="state.acls.length === 0">
                                <td colspan="5" class="text-center text-muted py-3 small">
                                    No access rules set. The model is globally accessible.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Section: Record Rules -->
                <div class="d-flex justify-content-between align-items-center mb-2 flex-shrink-0">
                    <h6 class="fw-bold text-dark mb-0">Row-Level Record Rules (ir.rule)</h6>
                    <button class="btn btn-outline-primary btn-xs" t-on-click="createNewRule">➕ Add Rule</button>
                </div>
                <div class="border rounded bg-white overflow-auto mb-3" style="max-height: 250px;">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-secondary sticky-top">
                            <tr>
                                <th scope="col" class="py-2 px-3 small">Rule Name</th>
                                <th scope="col" class="py-2 small">Domain Force</th>
                                <th scope="col" class="text-center py-2 small">Read</th>
                                <th scope="col" class="text-center py-2 small">Write</th>
                                <th scope="col" class="text-center py-2 small">Create</th>
                                <th scope="col" class="text-center py-2 small">Delete</th>
                                <th scope="col" class="text-center py-2 small">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.recordRules" t-as="rule" t-key="rule.id">
                                <tr>
                                    <td class="align-middle fw-bold text-dark py-2 px-3 small">
                                        <t t-esc="rule.name"/>
                                    </td>
                                    <td class="align-middle text-muted py-2 small font-monospace" style="font-size:0.7rem;">
                                        <t t-esc="rule.domain_force"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <span t-esc="rule.perm_read ? '✓' : '✗'" t-att-class="rule.perm_read ? 'text-success' : 'text-danger'"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <span t-esc="rule.perm_write ? '✓' : '✗'" t-att-class="rule.perm_write ? 'text-success' : 'text-danger'"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <span t-esc="rule.perm_create ? '✓' : '✗'" t-att-class="rule.perm_create ? 'text-success' : 'text-danger'"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <span t-esc="rule.perm_unlink ? '✓' : '✗'" t-att-class="rule.perm_unlink ? 'text-success' : 'text-danger'"/>
                                    </td>
                                    <td class="text-center align-middle py-2">
                                        <button class="btn btn-xs btn-outline-secondary py-0" t-on-click="() => this.editRule(rule)">Edit</button>
                                    </td>
                                </tr>
                            </t>
                            <tr t-if="state.recordRules.length === 0">
                                <td colspan="7" class="text-center text-muted py-3 small">
                                    No custom record rules configured.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
            
        </div>
    </t>
</templates>
