<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.AutomationEditor" owl="1">
        <div class="card p-3 mb-3 border shadow-sm" style="border-radius: 8px;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-bold text-dark small">⚡ Automation Rule Config</span>
                <span t-if="state.saving" class="spinner-border spinner-border-sm text-primary" role="status"></span>
            </div>

            <!-- Name Input -->
            <div class="mb-3">
                <label class="form-label text-secondary small fw-bold">Rule Name</label>
                <input type="text" class="form-control form-control-sm"
                       t-att-value="props.rule.name"
                       t-on-change="(ev) => this.updateRule('name', ev.target.value)"/>
            </div>

            <!-- Trigger Type Selection -->
            <div class="mb-2">
                <label class="form-label text-secondary small fw-bold">Trigger Event</label>
                <select class="form-select form-select-sm"
                        t-att-value="props.rule.trigger"
                        t-on-change="(ev) => this.updateRule('trigger', ev.target.value)">
                    <option value="on_create">On Creation (on_create)</option>
                    <option value="on_write">On Update (on_write)</option>
                    <option value="on_unlink">On Deletion (on_unlink)</option>
                </select>
            </div>
        </div>
    </t>
</templates>
