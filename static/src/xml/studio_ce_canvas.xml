<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeCanvas" owl="1">
        <div class="o_studio_ce_canvas d-flex flex-column h-100 bg-light p-3 position-relative">
            <!-- Canvas Header -->
            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                <div>
                    <h5 class="fw-bold text-dark mb-0">Live View Canvas</h5>
                    <small class="text-muted" t-if="props.view">Active view: <span class="font-monospace"><t t-esc="props.view.name"/></span></small>
                </div>
                
                <!-- Switchable view modes -->
                <div class="btn-group btn-group-sm shadow-sm" role="group">
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'canvas' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('canvas')">🛠️ Canvas Editor</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'form' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('form')">👁️ Form Preview</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'list' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('list')">👁️ List Preview</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'kanban' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('kanban')">👁️ Kanban Preview</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'xml' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('xml')">💻 Arch XML</button>
                </div>
            </div>

            <!-- Empty State / No View Loaded -->
            <div t-if="!props.view" class="flex-grow-1 d-flex flex-column justify-content-center align-items-center border-dashed rounded m-3 p-5">
                <span class="fs-1 mb-3">🖥️</span>
                <h5 class="fw-bold text-dark">No View Selected</h5>
                <p class="text-muted text-center max-w-sm">Please choose a view from the model views list or open an app to load the live editor canvas.</p>
            </div>

            <!-- Form/List Render Canvas -->
            <div t-else="" class="flex-grow-1 overflow-auto bg-white border rounded shadow-sm p-4">
                <t t-if="state.mode === 'canvas'">
                    <t t-foreach="state.archTree" t-as="rootNode" t-key="rootNode_index">
                        <t t-call="web_studio_ce.CanvasNode">
                            <t t-set="node" t-value="rootNode"/>
                        </t>
                    </t>
                </t>
                <t t-elif="state.mode === 'form'">
                    <t t-foreach="state.archTree" t-as="rootNode" t-key="rootNode_index">
                        <t t-call="web_studio_ce.FormPreviewNode">
                            <t t-set="node" t-value="rootNode"/>
                        </t>
                    </t>
                </t>
                <t t-elif="state.mode === 'list'">
                    <t t-foreach="state.archTree" t-as="rootNode" t-key="rootNode_index">
                        <t t-call="web_studio_ce.ListPreviewNode">
                            <t t-set="node" t-value="rootNode"/>
                        </t>
                    </t>
                </t>
                <t t-elif="state.mode === 'kanban'">
                    <t t-foreach="state.archTree" t-as="rootNode" t-key="rootNode_index">
                        <t t-call="web_studio_ce.KanbanPreviewNode">
                            <t t-set="node" t-value="rootNode"/>
                        </t>
                    </t>
                </t>
                <t t-elif="state.mode === 'xml'">
                    <div class="h-100 d-flex flex-column">
                        <textarea class="form-control flex-grow-1 font-monospace" readonly="1" style="font-size:0.8rem; background-color: #f8f9fa; min-height: 350px;" rows="15"><t t-esc="props.view ? props.view.arch : ''"/></textarea>
                    </div>
                </t>
            </div>

            <!-- Insert Field Wizard Modal -->
            <div t-if="state.showInsertModal" class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1" role="dialog" style="z-index: 1050;">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content shadow">
                        <div class="modal-header bg-primary text-white py-3">
                            <h5 class="modal-title fw-bold">📌 Insert Field Wizard</h5>
                            <button type="button" class="btn-close btn-close-white" t-on-click="closeInsertion"></button>
                        </div>
                        <div class="modal-body py-4">
                            <p class="small text-muted mb-4">Choose where to place the field <strong><t t-esc="state.insertingField ? state.insertingField.field_description : ''"/></strong> inside the form view.</p>
                            
                            <!-- Sibling Field Selector -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Position Relative to Field</label>
                                <select class="form-select form-select-sm" t-model="state.targetFieldName">
                                    <option value="">(None - append to sheet)</option>
                                    <t t-foreach="props.fields" t-as="f" t-key="f.id">
                                        <option t-att-value="f.name"><t t-esc="f.field_description"/> (<t t-esc="f.name"/>)</option>
                                    </t>
                                </select>
                            </div>

                            <!-- Position Mode -->
                            <div class="mb-3" t-if="state.targetFieldName">
                                <label class="form-label text-secondary small fw-bold">Insertion Placement</label>
                                <select class="form-select form-select-sm" t-model="state.insertPosition">
                                    <option value="after">After Sibling Field</option>
                                    <option value="before">Before Sibling Field</option>
                                </select>
                            </div>

                            <!-- Wrap in Group -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Create Inside New Group (Optional)</label>
                                <input type="text" class="form-control form-control-sm" placeholder="e.g. Sales Information" t-model="state.groupName"/>
                            </div>

                            <!-- Wrap in Notebook Page -->
                            <div class="mb-3">
                                <label class="form-label text-secondary small fw-bold">Create Inside New Notebook Tab (Optional)</label>
                                <input type="text" class="form-control form-control-sm" placeholder="e.g. Extra Settings" t-model="state.pageName"/>
                            </div>
                        </div>
                        <div class="modal-footer bg-light py-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="closeInsertion">Cancel</button>
                            <button type="button" class="btn btn-sm btn-primary px-3" t-on-click="submitInsertion">Insert Field</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Group Delete Confirmation Modal -->
            <div t-if="state.showDeleteConfirmation" class="modal fade show d-block bg-dark bg-opacity-50" tabindex="-1" role="dialog" style="z-index: 1060;">
                <div class="modal-dialog modal-dialog-centered" role="document">
                    <div class="modal-content shadow-lg border-danger">
                        <div class="modal-header bg-danger text-white py-3">
                            <h5 class="modal-title fw-bold">⚠️ Delete Group Container</h5>
                            <button type="button" class="btn-close btn-close-white" t-on-click="closeDeleteConfirmation"></button>
                        </div>
                        <div class="modal-body py-4">
                            <p class="mb-3">The group <strong class="text-danger"><t t-esc="state.groupToDelete ? (state.groupToDelete.attrs.string || 'Unnamed Group') : ''"/></strong> contains child elements (fields/nodes).</p>
                            <p class="text-muted small">Choose how you want to handle these child elements:</p>
                        </div>
                        <div class="modal-footer bg-light py-2 d-flex justify-content-between">
                            <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="closeDeleteConfirmation">Cancel</button>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-warning fw-bold text-white" t-on-click="unwrapGroup">Keep Fields (Move to Parent)</button>
                                <button type="button" class="btn btn-sm btn-danger fw-bold" t-on-click="confirmDeleteGroupAll">Remove All Contents</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Recursive Node Renderer Template -->
    <t t-name="web_studio_ce.CanvasNode" owl="1">
        <!-- Form Node -->
        <div t-if="node.name === 'form'" class="o_canvas_form_root">
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.CanvasNode"><t t-set="node" t-value="child"/></t>
            </t>
        </div>

        <!-- Sheet Node -->
        <div t-elif="node.name === 'sheet'" class="o_canvas_sheet border rounded shadow-sm p-4 bg-white mb-4 position-relative"
             t-on-dragover.stop.prevent="(ev) => this.onDragOverContainer(ev, node)"
             t-on-dragleave="(ev) => this.onDragLeaveContainer(ev)"
             t-on-drop.stop.prevent="(ev) => this.onDropContainer(ev, node)">
            <div class="position-absolute top-0 start-0 m-2 text-muted font-monospace" style="font-size: 0.65rem;">sheet</div>
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.CanvasNode"><t t-set="node" t-value="child"/></t>
            </t>
            <div t-if="node.children.length === 0" class="o_canvas_empty_placeholder text-center p-4 text-muted border border-dashed rounded my-2">
                Drop fields here
            </div>
        </div>

        <!-- Group Node -->
        <div t-elif="node.name === 'group'" 
             t-on-dragover.stop.prevent="(ev) => this.onDragOverContainer(ev, node)"
             t-on-dragleave="(ev) => this.onDragLeaveContainer(ev)"
             t-on-drop.stop.prevent="(ev) => this.onDropContainer(ev, node)"
             t-att-class="'o_canvas_group border rounded p-3 mb-3 bg-light bg-opacity-25 position-relative ' + 
                          ((props.selectedField &amp;&amp; props.selectedField.name === this.getNodeXpath(node)) ? 'border-primary shadow-sm bg-primary bg-opacity-10' : '')"
             t-on-click.stop="() => this.selectGroup(node)">
            
            <div class="o_canvas_group_header d-flex justify-content-between align-items-center border-bottom pb-1 mb-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="o_drag_handle text-muted cursor-grab" 
                          draggable="true"
                          t-on-dragstart="(ev) => this.onDragStartGroup(ev, node)">⋮⋮</span>
                    <span t-if="node.attrs.string" class="fw-bold text-secondary small"><t t-esc="node.attrs.string"/></span>
                    <span t-else="" class="fw-bold text-muted small font-italic">(Unnamed Group)</span>
                </div>
                <div class="d-flex gap-2">
                    <span class="text-muted font-monospace" style="font-size: 0.65rem;">group</span>
                    <button class="btn btn-xs py-0 px-1 border-0 bg-transparent text-danger fw-bold" 
                            t-on-click.stop="() => this.onDeleteGroupClick(node)">🗑️</button>
                </div>
            </div>
            
            <div class="row g-2">
                <t t-foreach="node.children" t-as="child" t-key="child_index">
                    <div class="col-md-6 col-sm-12">
                        <t t-call="web_studio_ce.CanvasNode"><t t-set="node" t-value="child"/></t>
                    </div>
                </t>
            </div>
            <div t-if="node.children.length === 0" class="o_canvas_empty_placeholder text-center p-3 text-muted border border-dashed rounded bg-white my-1">
                Drop fields here
            </div>
        </div>

        <!-- Notebook Node -->
        <div t-elif="node.name === 'notebook'" class="o_canvas_notebook card mb-3">
            <div class="card-header bg-light py-2">
                <ul class="nav nav-tabs card-header-tabs">
                    <t t-foreach="node.children" t-as="child" t-key="child_index">
                        <li class="nav-item">
                            <span class="nav-link py-1 px-3 active font-monospace small"><t t-esc="child.attrs.string || 'Tab'"/></span>
                        </li>
                    </t>
                </ul>
            </div>
            <div class="card-body">
                <t t-foreach="node.children" t-as="child" t-key="child_index">
                    <t t-call="web_studio_ce.CanvasNode"><t t-set="node" t-value="child"/></t>
                </t>
            </div>
        </div>

        <!-- Page Node -->
        <div t-elif="node.name === 'page'" class="o_canvas_page py-2"
             t-on-dragover.stop.prevent="(ev) => this.onDragOverContainer(ev, node)"
             t-on-dragleave="(ev) => this.onDragLeaveContainer(ev)"
             t-on-drop.stop.prevent="(ev) => this.onDropContainer(ev, node)">
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.CanvasNode"><t t-set="node" t-value="child"/></t>
            </t>
            <div t-if="node.children.length === 0" class="o_canvas_empty_placeholder text-center p-3 text-muted border border-dashed rounded bg-light bg-opacity-50 my-1">
                Drop fields here
            </div>
        </div>

        <!-- Field Node -->
        <div t-elif="node.name === 'field'" 
             t-on-dragover.stop.prevent="(ev) => this.onDragOverField(ev, node.attrs.name)"
             t-on-dragleave="(ev) => this.onDragLeaveField(ev)"
             t-on-drop.stop.prevent="(ev) => this.onDropField(ev, node.attrs.name)"
             t-att-class="'o_canvas_field_card d-flex flex-row align-items-center border rounded p-2 mb-2 cursor-pointer transition-all ' + 
                          ((props.selectedField &amp;&amp; props.selectedField.name === node.attrs.name) ? 'border-primary shadow-sm bg-primary bg-opacity-10' : 'bg-white border-light')"
             t-att-style="node.attrs.invisible === '1' ? 'opacity: 0.55; border-style: dashed !important;' : ''"
             t-on-click="() => this.selectField(node.attrs.name)">
            
            <!-- Grip Handle on the left -->
            <span class="o_drag_handle text-muted me-2 cursor-grab" 
                  draggable="true"
                  t-on-dragstart="(ev) => this.onDragStartField(ev, node.attrs.name, node.attrs.string || this.getFieldLabel(node.attrs.name))">⋮⋮</span>
            
            <!-- Content area of the field -->
            <div class="flex-grow-1 min-w-0">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="fw-bold text-dark small text-truncate">
                        <t t-esc="node.attrs.string || getFieldLabel(node.attrs.name)"/>
                    </span>
                    <div class="d-flex align-items-center gap-2">
                        <span t-if="node.attrs.required === '1' || node.attrs.required === 'True'" class="badge bg-danger text-white" style="font-size:0.6rem;">Required</span>
                        <span t-if="node.attrs.readonly === '1' || node.attrs.readonly === 'True'" class="badge bg-secondary text-white" style="font-size:0.6rem;">Read-only</span>
                        <button class="btn btn-xs py-0 px-1 border-0 bg-transparent text-secondary" 
                                t-att-title="node.attrs.invisible === '1' ? 'Show Field' : 'Hide Field'"
                                t-on-click.stop="() => props.onToggleVisibility(node.attrs.name, node.attrs.invisible !== '1')">
                            <t t-if="node.attrs.invisible === '1'">👁️‍🗨️</t>
                            <t t-else="">👁️</t>
                        </button>
                    </div>
                </div>
                <div class="font-monospace text-muted small bg-light p-1 rounded text-truncate" style="font-size: 0.75rem;">
                    &lt;field name="<t t-esc="node.attrs.name"/>" <t t-if="node.attrs.widget">widget="<t t-esc="node.attrs.widget"/>"</t>/&gt;
                </div>
            </div>
        </div>

        <!-- Generic / Fallback Node -->
        <div t-else="" class="o_canvas_generic_node border border-dashed rounded p-2 mb-2 text-muted font-monospace small bg-light text-center" style="font-size: 0.75rem;">
            &lt;<t t-esc="node.name"/>&gt;
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.CanvasNode"><t t-set="node" t-value="child"/></t>
            </t>
        </div>
    </t>

    <!-- Realistic Form Preview Template -->
    <t t-name="web_studio_ce.FormPreviewNode" owl="1">
        <!-- Form Node -->
        <div t-if="node.name === 'form'" class="o_form_view bg-light p-3 border rounded shadow-sm" style="min-height: 350px;">
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.FormPreviewNode"><t t-set="node" t-value="child"/></t>
            </t>
        </div>

        <!-- Header Node -->
        <div t-elif="node.name === 'header'" class="d-flex justify-content-between align-items-center bg-white border rounded shadow-sm p-2 mb-3">
            <div class="d-flex gap-2">
                <t t-foreach="node.children.filter(c => c.name === 'button')" t-as="btn" t-key="btn_index">
                    <button class="btn btn-sm btn-outline-secondary" disabled="1">
                        <t t-esc="btn.attrs.string || 'Button'"/>
                    </button>
                </t>
            </div>
            <!-- Render statusbar field if any -->
            <t t-foreach="node.children.filter(c => c.name === 'field')" t-as="fld" t-key="fld_index">
                <div class="d-flex gap-1 font-monospace text-secondary small">
                    <span class="badge bg-primary text-white py-1 px-2"><t t-esc="fld.attrs.name"/></span>
                </div>
            </t>
        </div>

        <!-- Sheet Node -->
        <div t-elif="node.name === 'sheet'" class="card shadow-sm border p-4 bg-white mb-4">
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.FormPreviewNode"><t t-set="node" t-value="child"/></t>
            </t>
        </div>

        <!-- Group Node -->
        <div t-elif="node.name === 'group'" class="mb-3">
            <div t-if="node.attrs.string" class="fw-bold border-bottom pb-1 mb-2 text-dark small"><t t-esc="node.attrs.string"/></div>
            <div class="row g-3">
                <t t-foreach="node.children" t-as="child" t-key="child_index">
                    <div class="col-sm-6 col-12">
                        <t t-call="web_studio_ce.FormPreviewNode"><t t-set="node" t-value="child"/></t>
                    </div>
                </t>
            </div>
        </div>

        <!-- Notebook Node -->
        <div t-elif="node.name === 'notebook'" class="card mb-3">
            <div class="card-header bg-light py-2">
                <ul class="nav nav-tabs card-header-tabs">
                    <t t-foreach="node.children" t-as="child" t-key="child_index">
                        <li class="nav-item">
                            <span class="nav-link py-1 px-3 active font-monospace small"><t t-esc="child.attrs.string || 'Tab'"/></span>
                        </li>
                    </t>
                </ul>
            </div>
            <div class="card-body">
                <t t-foreach="node.children" t-as="child" t-key="child_index">
                    <t t-call="web_studio_ce.FormPreviewNode"><t t-set="node" t-value="child"/></t>
                </t>
            </div>
        </div>

        <!-- Page Node -->
        <div t-elif="node.name === 'page'" class="py-2">
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.FormPreviewNode"><t t-set="node" t-value="child"/></t>
            </t>
        </div>

        <!-- Field Node -->
        <div t-elif="node.name === 'field'" class="mb-2">
            <t t-if="node.attrs.invisible !== '1'">
                <div class="row align-items-center">
                    <label class="col-sm-4 col-form-label text-muted fw-bold small text-sm-end text-start py-0">
                        <t t-esc="node.attrs.string || getFieldLabel(node.attrs.name)"/>
                    </label>
                    <div class="col-sm-8">
                        <input type="text" class="form-control form-control-sm bg-light" t-att-value="getMockValue(node.attrs.name, getFieldType(node.attrs.name), 1)" disabled="1"/>
                    </div>
                </div>
            </t>
        </div>

        <!-- Fallback Node -->
        <t t-else="">
            <t t-foreach="node.children" t-as="child" t-key="child_index">
                <t t-call="web_studio_ce.FormPreviewNode"><t t-set="node" t-value="child"/></t>
            </t>
        </t>
    </t>

    <!-- Realistic List Preview Template -->
    <t t-name="web_studio_ce.ListPreviewNode" owl="1">
        <!-- Render List/Tree View as a realistic table -->
        <div class="table-responsive border rounded bg-white shadow-sm mt-3">
            <table class="table table-hover table-striped mb-0 text-dark" style="font-size:0.85rem;">
                <thead class="bg-light">
                    <tr>
                        <th class="py-2 px-3 text-muted fw-bold border-bottom" style="width: 40px;"></th>
                        <t t-foreach="getListFields(node)" t-as="col" t-key="col.name">
                            <th class="py-2 px-3 text-muted fw-bold border-bottom">
                                <t t-esc="col.string"/>
                            </th>
                        </t>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="[1, 2, 3]" t-as="row" t-key="row">
                        <tr>
                            <td class="py-2 px-3 text-muted text-center"><input type="checkbox" class="form-check-input" disabled="1"/></td>
                            <t t-foreach="getListFields(node)" t-as="col" t-key="col.name">
                                <td class="py-2 px-3 align-middle">
                                    <t t-esc="getMockValue(col.name, col.type, row)"/>
                                </td>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
    </t>

    <!-- Realistic Kanban Preview Template -->
    <t t-name="web_studio_ce.KanbanPreviewNode" owl="1">
        <div class="o_kanban_view bg-light p-3 border rounded shadow-sm">
            <div class="row g-3">
                <t t-foreach="[1, 2, 3, 4]" t-as="row" t-key="row">
                    <div class="col-md-4 col-sm-6 col-12">
                        <div class="card p-3 bg-white shadow-sm border-light">
                            <t t-foreach="getListFields(node).slice(0, 3)" t-as="col" t-key="col.name">
                                <div class="mb-1 text-truncate">
                                    <strong class="small text-muted"><t t-esc="col.string"/>:</strong>
                                    <span class="small text-dark ms-1"><t t-esc="getMockValue(col.name, col.type, row)"/></span>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
