<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeCanvas" owl="1">
        <div class="o_studio_ce_canvas d-flex flex-column h-100 bg-light p-3 position-relative">
            <!-- Canvas Header -->
            <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                <div>
                    <h5 class="fw-bold text-dark mb-0">Live View Canvas</h5>
                    <small class="text-muted" t-if="props.view">Active view: <span class="font-monospace"><t t-esc="props.view.name"/></span></small>
                </div>
                
                <!-- Switchable view modes -->
                <div class="btn-group btn-group-sm shadow-sm" role="group">
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'canvas' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('canvas')">🛠️ Canvas Editor</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'form' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('form')">👁️ Form Preview</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'list' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('list')">👁️ List Preview</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'kanban' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('kanban')">👁️ Kanban Preview</button>
                    <button type="button" class="btn py-1 px-3"
                            t-att-class="state.mode === 'xml' ? 'btn-primary fw-bold' : 'btn-outline-primary'"
                            t-on-click="() => this.switchMode('xml')">💻 Arch XML</button>
                </div>
            </div>

            <!-- Empty State / No View Loaded -->
            <div t-if="!props.view" class="flex-grow-1 d-flex flex-column justify-content-center align-items-center border-dashed rounded m-3 p-5">
                <span class="fs-1 mb-3">🖥️</span>
                <h5 class="fw-bold text-dark">No View Selected</h5>
                <p class="text-muted text-center max-w-sm">Please choose a view from the model views list or open an app to load the live editor canvas.</p>
            </div>

            <!-- Form/List Render Canvas -->
            <div t-else="" class="flex-grow-1 overflow-auto bg-white border rounded shadow-sm p-4">
                <t t-if="state.mode === 'xml'">
                    <div class="h-100 d-flex flex-column">
                        <textarea class="form-control flex-grow-1 font-monospace" readonly="1" style="font-size:0.8rem; background-color: #f8f9fa; min-height: 350px;" rows="15"><t t-esc="props.view ? props.view.arch : ''"/></textarea>
                    </div>
                </t>
                <t t-else="">
                    <!-- Native Odoo View component instantiation -->
                    <View type="getViewType()"
                          resModel="props.model"
                          viewId="props.view.id"
                          display="{ controlPanel: false }"/>
                </t>
            </div>
        </div>
    </t>
</templates>
