<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web_studio_ce.StudioCeCanvas" owl="1">
        <div class="o_studio_ce_canvas h-100 d-flex flex-column position-relative bg-light p-3">
            <!-- Canvas Header & Mode Switcher -->
            <div class="o_studio_ce_canvas_header bg-white border-bottom p-2 d-flex justify-content-between align-items-center mb-3 rounded shadow-sm flex-shrink-0">
                <div class="d-flex align-items-center gap-3">
                    <span class="fw-bold text-dark small">🖥️ Design Workspace Canvas</span>
                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-primary py-1 px-3" 
                                t-att-class="state.viewMode === 'preview' ? 'active fw-bold' : ''"
                                t-on-click="() => state.viewMode = 'preview'">Live Preview</button>
                        <button class="btn btn-outline-primary py-1 px-3" 
                                t-att-class="state.viewMode === 'layout' ? 'active fw-bold' : ''"
                                t-on-click="() => state.viewMode = 'layout'">XML Layout Blocks</button>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge bg-primary text-uppercase" t-if="props.view" t-esc="props.view.type"/>
                    <span class="text-muted small" t-if="props.view" t-esc="props.view.name"/>
                </div>
            </div>

            <!-- Main Render Area -->
            <div class="o_studio_ce_block_root flex-grow-1 overflow-auto bg-white border rounded shadow-sm p-4">
                <t t-if="state.blocks.length">
                    <!-- 1. Live Preview Mode -->
                    <t t-if="state.viewMode === 'preview'">
                        <t t-if="props.view.type === 'form'">
                            <t t-call="web_studio_ce.StudioCeFormPreview"/>
                        </t>
                        <t t-elif="props.view.type === 'list' || props.view.type === 'tree'">
                            <t t-call="web_studio_ce.StudioCeListPreview"/>
                        </t>
                        <t t-elif="props.view.type === 'kanban'">
                            <t t-call="web_studio_ce.StudioCeKanbanPreview"/>
                        </t>
                        <t t-else="">
                            <!-- Fallback layout mode if no preview available -->
                            <t t-foreach="state.blocks" t-as="block" t-key="block.id">
                                <t t-call="web_studio_ce.StudioCeBlockNode">
                                    <t t-set="block" t-value="block"/>
                                </t>
                            </t>
                        </t>
                    </t>

                    <!-- 2. XML Layout Blocks Builder Mode -->
                    <t t-else="">
                        <t t-foreach="state.blocks" t-as="block" t-key="block.id">
                            <t t-call="web_studio_ce.StudioCeBlockNode">
                                <t t-set="block" t-value="block"/>
                            </t>
                        </t>
                    </t>
                </t>
                <t t-else="">
                    <div class="text-center text-muted py-5">
                        <span class="fs-1 mb-2 d-block">📄</span>
                        <p class="mb-0">No layouts or elements defined in this view.</p>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <!-- Recursive Block Template -->
    <t t-name="web_studio_ce.StudioCeBlockNode" owl="1">
        <div t-att-class="getBlockClass(block)"
             t-att-data-xpath="block.xpath"
             t-on-click.stop="() => this.selectBlock(block)"
             t-on-dblclick.stop="() => this.renameBlockInline(block)"
             class="o_studio_ce_block position-relative border rounded my-2 p-3 bg-white shadow-sm border-start border-3">
             
             <!-- Drag Handle (positioned absolute left) -->
             <span class="o_studio_ce_block_drag_handle position-absolute start-0 top-0 bottom-0 d-flex align-items-center justify-content-center bg-light text-muted border-end" 
                   style="width: 24px; cursor: grab;"
                   draggable="true"
                   t-on-dragstart.stop="(ev) => this.onBlockDragStart(ev, block)">
                 ⋮⋮
             </span>

             <div class="d-flex justify-content-between align-items-center ms-3 ps-2">
                 <div class="d-flex align-items-center gap-2">
                     <span t-att-class="'badge text-uppercase ' + (block.tag === 'field' ? 'bg-primary text-white' : (block.tag === 'group' ? 'bg-purple text-white' : 'bg-secondary text-white'))" t-esc="block.tag"/>
                     <strong class="text-dark" t-esc="getBlockLabel(block)"/>
                     <span class="text-muted font-monospace small" t-if="block.attrs.name">(<t t-esc="block.attrs.name"/>)</span>
                 </div>
                 <div class="d-flex align-items-center gap-2">
                     <button class="btn btn-xs btn-outline-danger border-0 p-1" title="Delete" t-on-click.stop="() => this.deleteBlock(block)">🗑️</button>
                 </div>
             </div>

             <!-- Drop Zone Inside Container Elements -->
             <div t-if="isContainer(block)" 
                  class="o_studio_ce_block_children ms-3 ps-2 mt-3 p-3 border border-dashed rounded bg-light bg-opacity-25"
                  style="min-height: 50px;"
                  t-att-data-xpath="block.xpath"
                  t-on-dragover.prevent.stop="onBlockDragOver"
                  t-on-dragleave.stop="onBlockDragLeave"
                  t-on-drop.stop="(ev) => this.onBlockDrop(ev, block, 'inside')">
                  
                  <!-- Loop children -->
                  <t t-foreach="block.children" t-as="child" t-key="child.id">
                      <!-- Drop Zone Before each child -->
                      <div class="o_studio_ce_drop_zone my-1 rounded border border-dashed"
                           t-att-data-xpath="child.xpath"
                           t-att-data-position="'before'"
                           t-on-dragover.prevent.stop="onBlockDragOver"
                           t-on-dragleave.stop="onBlockDragLeave"
                           t-on-drop.stop="(ev) => this.onBlockDrop(ev, child, 'before')">
                          <span class="text-muted small px-2 py-1 d-block text-center font-monospace" style="font-size: 0.65rem;">↓ Drop here to place before <t t-esc="getBlockLabel(child)"/></span>
                      </div>
                      
                      <!-- Recurse child block -->
                      <t t-call="web_studio_ce.StudioCeBlockNode">
                          <t t-set="block" t-value="child"/>
                      </t>
                  </t>
                  
                  <div t-if="block.children.length === 0" class="text-center text-muted py-3 small font-monospace" style="font-size: 0.72rem;">
                      Empty <t t-esc="block.tag"/> (Drop items here)
                  </div>
             </div>
        </div>
    </t>

    <!-- 1. Form View Preview Template -->
    <t t-name="web_studio_ce.StudioCeFormPreview" owl="1">
        <div class="o_form_view o_form_readonly bg-white border rounded shadow-sm p-4 mx-auto" style="max-width: 850px; min-height: 600px;">
            <!-- Mock Header Statusbar -->
            <div class="o_form_statusbar border-bottom pb-2 mb-3 d-flex justify-content-between align-items-center">
                <div class="o_statusbar_buttons d-flex gap-2">
                    <button class="btn btn-secondary btn-sm" disabled="1">Edit</button>
                    <button class="btn btn-secondary btn-sm" disabled="1">Create</button>
                </div>
                <div class="o_statusbar_status d-flex gap-1 align-items-center">
                    <span class="text-secondary small cursor-pointer opacity-75" style="font-size:0.78rem; font-weight: 500; cursor: pointer;">Add a pipeline status bar</span>
                </div>
            </div>

            <!-- Mock Sheet -->
            <div class="o_form_sheet position-relative p-4 border rounded shadow-xs" style="min-height: 400px;">
                <!-- Mock Button Box -->
                <div class="oe_button_box d-flex justify-content-end border-bottom mb-2 pb-1 gap-2 bg-light p-2 rounded"
                     style="min-height: 45px;"
                     t-on-dragover.prevent.stop="onBlockDragOver"
                     t-on-dragleave.stop="onBlockDragLeave"
                     t-on-drop.stop="(ev) => this.onBlockDrop(ev, {xpath: '//div[@name=\'button_box\']'}, 'inside')">
                    <t t-if="statButtons.length">
                        <t t-foreach="statButtons" t-as="btn" t-key="btn.id">
                            <button t-att-class="getBlockClass(btn) + ' btn btn-outline-secondary btn-sm d-flex align-items-center gap-1 py-1 px-2 oe_stat_button'"
                                    t-on-click.stop="() => this.selectBlock(btn)"
                                    style="min-width: 100px; font-size: 0.75rem;">
                                <span><i t-attf-class="fa {{btn.attrs.icon || 'fa-star'}} text-primary"/></span>
                                <div class="text-start text-truncate" style="line-height: 1;">
                                    <div class="fw-bold text-dark text-truncate"><t t-esc="btn.attrs.string || 'Stat Button'"/></div>
                                    <div class="text-muted" style="font-size:0.6rem;">[<t t-esc="btn.attrs.name || 'action'"/>]</div>
                                </div>
                            </button>
                        </t>
                    </t>
                    <t t-else="">
                        <div class="text-muted small italic d-flex align-items-center justify-content-center w-100 font-monospace" style="font-size: 0.7rem;">
                            Drop smart buttons here
                        </div>
                    </t>
                </div>

                <div class="mb-3">
                    <span class="text-success cursor-pointer small font-weight-bold" style="color: #00878a !important; cursor: pointer; font-size: 0.82rem;">Add a button</span>
                </div>

                <t t-foreach="sheetChildren" t-as="block" t-key="block.id">
                    <t t-call="web_studio_ce.StudioCeFormElement">
                        <t t-set="block" t-value="block"/>
                    </t>
                </t>

                <!-- Mock Chatter Widget -->
                <div class="o_studio_ce_chatter_mock">
                    <div class="d-flex gap-2 mb-3">
                        <button class="btn btn-secondary btn-chatter text-dark bg-light border" disabled="1">Send message</button>
                        <button class="btn btn-secondary btn-chatter text-dark bg-light border" disabled="1">Log note</button>
                        <button class="btn btn-secondary btn-chatter text-dark bg-light border" disabled="1">Activity</button>
                    </div>
                    
                    <div class="chatter-activity-row">
                        <div class="chatter-avatar">MA</div>
                        <div class="chatter-content">
                            <div class="d-flex align-items-center gap-2">
                                <strong class="text-dark">Mitchell Admin</strong>
                                <span class="text-muted" style="font-size:0.7rem;">5:20 PM</span>
                            </div>
                            <div class="text-muted mt-1">Creating a new record...</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

    <!-- Form Element Component Renderer -->
    <t t-name="web_studio_ce.StudioCeFormElement" owl="1">
        <!-- Group -->
        <t t-if="block.tag === 'group'">
            <div t-att-class="getBlockClass(block) + ' o_studio_ce_group mb-3 border rounded border-dashed p-3'"
                 t-att-data-xpath="block.xpath"
                 t-on-click.stop="() => this.selectBlock(block)"
                 style="cursor: pointer;">
                <div class="text-uppercase text-muted fw-bold mb-2" style="font-size: 0.65rem;">
                    📂 <t t-esc="block.attrs.string || 'Group Container'"/>
                </div>
                
                <t t-if="hasSubGroups(block)">
                    <div class="row g-3">
                        <t t-foreach="block.children" t-as="sub" t-key="sub.id">
                            <div class="col-md-6">
                                <t t-call="web_studio_ce.StudioCeFormElement">
                                    <t t-set="block" t-value="sub"/>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <div class="d-flex flex-column gap-2">
                        <t t-foreach="block.children" t-as="sub" t-key="sub.id">
                            <t t-call="web_studio_ce.StudioCeFormElement">
                                <t t-set="block" t-value="sub"/>
                            </t>
                        </t>
                    </div>
                </t>
            </div>
        </t>

        <!-- Field -->
        <t t-elif="block.tag === 'field'">
            <div t-att-class="getBlockClass(block) + ' o_studio_ce_field d-flex align-items-center mb-2 p-2 border rounded bg-white'"
                 t-att-data-xpath="block.xpath"
                 t-on-click.stop="() => this.selectBlock(block)"
                 style="cursor: pointer; min-height: 48px;">
                 <label class="text-secondary small fw-bold me-2 text-truncate" style="width: 150px;">
                     <t t-esc="getBlockLabel(block)"/>
                 </label>
                 
                 <!-- Dynamic mock renderer per field type -->
                 <div class="flex-grow-1">
                     <t t-set="f_type" t-value="props.fields.find(f => f.name === block.attrs.name) ? props.fields.find(f => f.name === block.attrs.name).ttype : 'char'"/>
                     
                     <!-- 1. Boolean Checkbox -->
                     <t t-if="f_type === 'boolean'">
                         <div class="form-check form-switch m-0">
                             <input type="checkbox" class="form-check-input" checked="1" disabled="1" style="cursor: pointer;"/>
                         </div>
                     </t>

                     <!-- 2. Many2one relation lookup -->
                     <t t-elif="f_type === 'many2one'">
                         <div class="o_field_widget o_field_many2one d-flex align-items-center position-relative w-100">
                             <div class="o_input_dropdown flex-grow-1 d-flex align-items-center border rounded bg-light px-2" style="height: 30px;">
                                 <input type="text" class="o_input border-0 bg-transparent flex-grow-1 p-0 small text-dark" t-att-value="getMockValue(block)" disabled="1" style="font-size:0.8rem; outline: none;"/>
                                 <span class="text-muted ms-1" style="font-size: 0.7rem;">▼</span>
                             </div>
                         </div>
                     </t>

                     <!-- 3. Many2many tag list -->
                     <t t-elif="f_type === 'many2many'">
                         <div class="o_field_tags d-flex flex-wrap gap-1 align-items-center">
                             <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-2 py-1" style="font-size: 0.7rem;">Tag Sample A</span>
                             <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-2 py-1" style="font-size: 0.7rem;">Tag Sample B</span>
                         </div>
                     </t>

                     <!-- 4. Selection Dropdown -->
                     <t t-elif="f_type === 'selection'">
                         <select class="o_input form-select form-select-sm" disabled="1" style="height: 30px; font-size: 0.8rem;">
                             <option t-esc="getMockValue(block)"/>
                         </select>
                     </t>

                     <!-- 5. Monetary input group -->
                     <t t-elif="f_type === 'monetary'">
                         <div class="input-group input-group-sm" style="max-width: 200px;">
                             <span class="input-group-text bg-light border text-muted py-0 px-2" style="font-size:0.75rem;">$</span>
                             <input type="text" class="form-control form-control-sm border text-end" t-att-value="getMockValue(block)" disabled="1" style="font-size:0.8rem;"/>
                         </div>
                     </t>

                     <!-- 6. Date / Datetime -->
                     <t t-elif="f_type === 'date' || f_type === 'datetime'">
                         <div class="d-flex align-items-center border rounded bg-light px-2" style="height: 30px; max-width: 220px;">
                             <span class="me-1 text-muted" style="font-size: 0.85rem;">📅</span>
                             <input type="text" class="border-0 bg-transparent flex-grow-1 p-0 small text-dark" t-att-value="getMockValue(block)" disabled="1" style="font-size:0.8rem; outline: none;"/>
                         </div>
                     </t>

                     <!-- 7. HTML widget -->
                     <t t-elif="f_type === 'html'">
                         <div class="border rounded bg-light p-2 text-muted text-wrap overflow-hidden small" style="min-height: 50px; font-size:0.75rem; max-height: 100px;">
                             <t t-out="getMockValue(block)"/>
                         </div>
                     </t>

                     <!-- 8. Binary / File Upload -->
                     <t t-elif="f_type === 'binary'">
                         <div class="d-flex align-items-center gap-2">
                             <button class="btn btn-xs btn-outline-primary py-0 px-2" disabled="1" style="font-size:0.7rem;">📎 Upload File</button>
                             <span class="text-muted font-monospace" style="font-size:0.7rem;"><t t-esc="getMockValue(block)"/></span>
                         </div>
                     </t>

                     <!-- Default Text/Char/Integer/Float -->
                     <t t-else="">
                         <input type="text" class="o_input form-control form-control-sm border" t-att-value="getMockValue(block)" disabled="1" style="height: 30px; font-size: 0.8rem;"/>
                     </t>
                 </div>
            </div>
        </t>

        <!-- Notebook -->
        <t t-elif="block.tag === 'notebook'">
            <div class="o_notebook mt-4 border rounded p-3 bg-light">
                <ul class="nav nav-tabs nav-fill mb-3">
                    <t t-foreach="block.children" t-as="page" t-key="page.id">
                        <li class="nav-item">
                            <span class="nav-link py-1 active fw-bold small text-primary"><t t-esc="getBlockLabel(page)"/></span>
                        </li>
                    </t>
                </ul>
                <div class="tab-content bg-white p-3 border rounded">
                    <t t-if="block.children.length">
                        <t t-foreach="block.children[0].children" t-as="sub" t-key="sub.id">
                            <t t-call="web_studio_ce.StudioCeFormElement">
                                <t t-set="block" t-value="sub"/>
                            </t>
                        </t>
                    </t>
                </div>
            </div>
        </t>

        <!-- Fallback block cards -->
        <t t-else="">
            <div t-att-class="getBlockClass(block) + ' border rounded my-2 p-2 bg-light'"
                 t-att-data-xpath="block.xpath"
                 t-on-click.stop="() => this.selectBlock(block)">
                 <div class="small fw-bold text-muted text-uppercase mb-1">&lt;<t t-esc="block.tag"/>&gt;</div>
                 <t t-foreach="block.children" t-as="sub" t-key="sub.id">
                     <t t-call="web_studio_ce.StudioCeFormElement">
                         <t t-set="block" t-value="sub"/>
                     </t>
                 </t>
            </div>
        </t>
    </t>

    <!-- 2. List View Preview Template -->
    <t t-name="web_studio_ce.StudioCeListPreview" owl="1">
        <div class="o_list_view bg-white border rounded shadow-sm overflow-auto" style="min-height: 400px;">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40px;"></th>
                        <t t-foreach="listFields" t-as="fieldBlock" t-key="fieldBlock.id">
                            <th t-att-class="getBlockClass(fieldBlock) + ' py-2'"
                                t-att-data-xpath="fieldBlock.xpath"
                                t-on-click.stop="() => this.selectBlock(fieldBlock)"
                                style="cursor: pointer; font-size:0.85rem;">
                                📋 <t t-esc="getBlockLabel(fieldBlock)"/>
                            </th>
                        </t>
                    </tr>
                </thead>
                 <tbody>
                    <t t-foreach="[1, 2, 3]" t-as="row" t-key="row">
                        <tr>
                            <td class="text-muted text-center py-2">⋮⋮</td>
                            <t t-foreach="listFields" t-as="fieldBlock" t-key="fieldBlock.id">
                                <td class="py-2 text-muted small">
                                    <t t-esc="getMockValue(fieldBlock)"/>
                                </td>
                            </t>
                        </tr>
                    </t>
                 </tbody>
            </table>
        </div>
    </t>

    <!-- 3. Kanban View Preview Template -->
    <t t-name="web_studio_ce.StudioCeKanbanPreview" owl="1">
        <div class="o_kanban_view bg-light border rounded shadow-sm p-3 d-flex gap-3 overflow-auto" style="min-height: 400px;">
            <t t-foreach="['Draft', 'In Progress', 'Done']" t-as="col" t-key="col">
                <div class="o_kanban_group flex-grow-1 border rounded bg-white bg-opacity-75 p-2 d-flex flex-column gap-2" style="min-width: 220px; max-width: 280px;">
                    <div class="o_kanban_header fw-bold text-secondary border-bottom pb-1 mb-2 d-flex justify-content-between align-items-center">
                        <span class="small font-weight-bold" t-esc="col"/>
                        <span class="badge bg-secondary rounded-circle" style="font-size:0.65rem;">2</span>
                    </div>
                    <t t-foreach="[1, 2]" t-as="card" t-key="card">
                        <div class="o_kanban_record border rounded p-2 bg-white shadow-xs d-flex flex-column gap-1">
                            <t t-foreach="listFields.slice(0, 3)" t-as="fieldBlock" t-key="fieldBlock.id">
                                <div class="text-truncate small">
                                    <span class="text-secondary small" t-esc="getBlockLabel(fieldBlock)"/>: 
                                    <strong class="text-dark"><t t-esc="getMockValue(fieldBlock)"/></strong>
                                </div>
                            </t>
                            <div class="d-flex justify-content-between align-items-center mt-2 border-top pt-1">
                                <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:0.6rem;">🏷️ Tag</span>
                                <span class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center small fw-bold" style="width: 18px; height: 18px; font-size: 8px;">U</span>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>
